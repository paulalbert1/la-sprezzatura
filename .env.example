# Sanity CMS
# Get these from your Sanity project: https://www.sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production

# Resend — for contact form email delivery
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address to receive contact form notifications (Liz's inbox)
# Note: In Resend sandbox mode (without a verified domain), this must be
# the email address of the Resend account owner.
CONTACT_NOTIFY_EMAIL=liz@lasprezz.com

# Sanity Write Token -- for portal client actions (notes, approvals, warranty claims)
# Create in Sanity Dashboard -> Settings -> API -> Tokens (Editor role)
# IMPORTANT: Never prefix with PUBLIC_ -- this token must stay server-side only
SANITY_WRITE_TOKEN=your_write_token_here

# Vercel Blob (private document storage -- COIs, estimates, floor plans, legal docs)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Studio API Secret -- shared secret for rendering API routes
# STUDIO_API_SECRET is used server-side; SANITY_STUDIO_API_SECRET is the same value
# but prefixed for Sanity Studio client-side bundling (Vite only bundles SANITY_STUDIO_ prefix)
STUDIO_API_SECRET=your_studio_secret_here
SANITY_STUDIO_API_SECRET=your_studio_secret_here

# Vercel Cron shared secret -- set this in the Vercel project env, then any
# request to /api/cron/* that does NOT carry "Authorization: Bearer ${CRON_SECRET}"
# (Vercel Cron's default header) OR "x-cron-secret: ${CRON_SECRET}" (manual / local
# invocation per Phase 36 D-12) is rejected with 401.
CRON_SECRET=replace_with_a_long_random_string

# Impersonation fresh-auth threshold (Phase 49 D-10, IMPER-08)
# Mint endpoint /api/admin/impersonate refuses with HTTP 401
# { error: "Fresh authentication required", code: "reauth_required" }
# when the admin session's mintedAt is older than this many seconds.
# Default 900 = 15 min. Read once at module load.
IMPERSONATION_FRESH_AUTH_MAX_AGE_SEC=900
