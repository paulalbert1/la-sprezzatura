---
import SanityImage from "../SanityImage.astro";

interface Project {
  _id: string;
  title: string;
  slug: { current: string };
  heroImage?: any;
  roomType?: string;
  location?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

{
  projects && projects.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {projects.map((project, index) => (
        <a
          href={`/portfolio/${project.slug.current}`}
          class:list={[
            "group block featured-card",
            index === 0 && "md:col-span-2 lg:col-span-2",
          ]}
          data-animate="fade-up"
        >
          <article class="overflow-hidden">
            <div class="overflow-hidden aspect-[4/3] relative">
              {project.heroImage ? (
                <SanityImage
                  image={project.heroImage}
                  alt={project.title}
                  sizes={
                    index === 0
                      ? "(max-width: 768px) 100vw, 66vw"
                      : "(max-width: 768px) 100vw, 33vw"
                  }
                  widths={index === 0 ? [640, 1024, 1440] : [400, 640, 800]}
                  class="w-full h-full transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-cream-dark to-stone-light" />
              )}
            </div>
            <div class="pt-5 pb-2">
              {project.roomType && (
                <p class="text-xs uppercase tracking-widest text-stone mb-2 font-body">
                  {project.roomType}
                </p>
              )}
              <h3 class="font-heading text-2xl md:text-3xl font-light text-charcoal leading-tight group-hover:text-terracotta transition-colors duration-300">
                {project.title}
              </h3>
              {project.location && (
                <p class="text-sm text-stone mt-1.5 font-body">
                  {project.location}
                </p>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>
  ) : null
}
