---
interface Props {
  stage: string;
  isComplete: boolean;
}

const { stage, isComplete } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center px-4 py-1.5 rounded-full text-sm font-body font-medium tracking-wide",
    isComplete
      ? "bg-emerald-50 text-emerald-700"
      : "bg-terracotta/10 text-terracotta",
  ]}
>
  {stage}
</span>
