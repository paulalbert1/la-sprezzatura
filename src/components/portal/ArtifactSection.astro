---
import type { Artifact } from "../../lib/artifactUtils";
import ArtifactCard from "./ArtifactCard.astro";

interface Props {
  artifacts: Artifact[];
  projectId: string;
  isCompleted: boolean;
}

const { artifacts, projectId, isCompleted } = Astro.props;
---

<section class="py-12 border-t border-stone-light/20">
  <h2 class="font-heading text-xl font-light text-charcoal mb-6">
    Documents & Artifacts
  </h2>

  {
    artifacts.length === 0 ? (
      <div class="text-center py-8">
        <p class="text-sm text-stone font-body font-light">
          No documents uploaded yet.
        </p>
        <p class="text-xs text-stone-light font-body mt-1">
          Liz will share design materials here as your project progresses.
        </p>
      </div>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {artifacts.map((artifact) => (
          <ArtifactCard
            artifact={artifact}
            projectId={projectId}
            isCompleted={isCompleted}
          />
        ))}
      </div>
    )
  }
</section>
