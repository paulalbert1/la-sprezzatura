---
import {
  getMilestoneStatus,
  formatRelativeDate,
  type Milestone,
} from "../../lib/milestoneUtils";
import ClientNoteForm from "./ClientNoteForm.tsx";

interface Props {
  milestone: Milestone;
  isFirstIncomplete: boolean;
  isCompleted: boolean;
  projectId: string;
}

const { milestone, isFirstIncomplete, isCompleted, projectId } = Astro.props;

const status = getMilestoneStatus(milestone, isFirstIncomplete);
const formattedDate = milestone.date
  ? new Date(milestone.date + "T00:00:00").toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  : null;
const relativeDate = milestone.date
  ? formatRelativeDate(milestone.date)
  : null;
const isOverdue = status === "overdue";
const isCurrent = status === "current";
const isCompleted_ = status === "completed";
const isUpcoming = status === "upcoming";
---

<div
  class:list={[
    "flex gap-4 py-4",
    isCurrent && "border-l-4 border-l-terracotta pl-4 -ml-4 bg-terracotta/[0.03]",
  ]}
>
  <!-- Status dot -->
  <div class="flex flex-col items-center">
    <div
      class:list={[
        "w-7 h-7 rounded-full flex items-center justify-center shrink-0",
        isCompleted_ && "bg-emerald-600 text-white",
        isCurrent &&
          "bg-cream ring-4 ring-terracotta/20 border-2 border-terracotta",
        isOverdue && "bg-cream border-2 border-amber-400",
        isUpcoming &&
          "bg-cream-dark border-2 border-stone-light/40",
      ]}
    >
      {isCompleted_ && (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-3.5 h-3.5"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
      )}
    </div>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline justify-between gap-2">
      <h3
        class:list={[
          "font-body text-base",
          isCompleted_ && "text-stone",
          isCurrent && "text-charcoal font-medium",
          isOverdue && "text-charcoal",
          isUpcoming && "text-stone",
        ]}
      >
        {milestone.name}
      </h3>
      {formattedDate && (
        <div class="flex items-center gap-2 shrink-0">
          <span
            class:list={[
              "text-xs font-body tabular-nums",
              isOverdue ? "text-amber-600" : isCompleted_ ? "text-stone-light" : "text-stone",
            ]}
          >
            {formattedDate}
          </span>
          {!milestone.completed && relativeDate && (
            <span
              class:list={[
                "text-xs font-body",
                isOverdue
                  ? "text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full"
                  : "text-stone-light",
              ]}
            >
              {isOverdue ? "Overdue" : relativeDate}
            </span>
          )}
        </div>
      )}
    </div>

    {milestone.description && (
      <p
        class:list={[
          "text-sm font-body mt-1 leading-relaxed",
          isCompleted_ ? "text-stone-light" : "text-stone",
        ]}
      >
        {milestone.description}
      </p>
    )}

    <!-- Existing notes -->
    {milestone.notes && milestone.notes.length > 0 && (
      <div class="mt-3 space-y-2">
        {milestone.notes.map((note) => (
          <div class="bg-cream-dark px-3 py-2 text-xs font-body">
            <span class="text-charcoal tracking-wide">{note.clientName}</span>
            <span class="text-stone-light mx-1">&middot;</span>
            <span class="text-stone-light">
              {new Date(note.timestamp).toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })}
            </span>
            <p class="text-stone mt-1">{note.text}</p>
          </div>
        ))}
      </div>
    )}

    {!isCompleted && (
      <details class="mt-2 group">
        <summary class="text-xs text-stone hover:text-terracotta transition-colors font-body cursor-pointer select-none">
          Add a note
        </summary>
        <div class="mt-2">
          <ClientNoteForm
            client:load
            projectId={projectId}
            targetKey={milestone._key}
            targetType="milestone"
          />
        </div>
      </details>
    )}
  </div>
</div>
