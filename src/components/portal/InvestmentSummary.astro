---
import type { InvestmentTier } from "../../lib/artifactUtils";
import { formatCurrency } from "../../lib/formatCurrency";
import TierSelectionForm from "./TierSelectionForm.tsx";

interface Props {
  tiers: InvestmentTier[];
  selectedTierKey?: string;
  eagerness?: number;
  projectId: string;
  artifactKey: string;
  isCompleted: boolean;
}

const { tiers, selectedTierKey, eagerness, projectId, artifactKey, isCompleted } = Astro.props;

const tierCount = tiers.length;
const gridCols = tierCount <= 3 ? tierCount : 2;
const selectedTierName = selectedTierKey
  ? tiers.find((t) => t._key === selectedTierKey)?.name || "Selected tier"
  : undefined;
---

<section class="mt-6">
  <h3 class="font-heading text-xl font-light text-charcoal mb-6">Investment Summary</h3>

  {tiers.length === 0 && (
    <p class="text-sm text-stone font-body">Investment options are being prepared for your review.</p>
  )}

  {tiers.length > 0 && (
    <div class:list={[
      "grid gap-5 grid-cols-1",
      gridCols === 2 && "md:grid-cols-2",
      gridCols === 3 && "md:grid-cols-3",
    ]}>
      {tiers.map((tier, tierIndex) => {
        const isSelected = selectedTierKey === tier._key;
        const otherSelected = selectedTierKey && !isSelected;
        const total = tier.lineItems.reduce((sum, item) => sum + (item.price || 0), 0);

        return (
          <div
            class:list={[
              "bg-cream-dark border flex flex-col min-w-0",
              isSelected
                ? "border-emerald-400 border-2 ring-1 ring-emerald-100"
                : "border-stone-light/20",
              otherSelected && "opacity-40",
            ]}
          >
            {/* Tier header with name and total */}
            <div class="p-5 pb-4 border-b border-stone-light/20">
              <div class="flex items-baseline justify-between gap-3">
                <h4 class="font-heading text-lg font-light text-charcoal">{tier.name}</h4>
                {isSelected && (
                  <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs tracking-wide bg-emerald-50 text-emerald-700 font-body shrink-0">
                    Selected
                  </span>
                )}
              </div>
              <p class="font-heading text-2xl text-charcoal mt-1 text-right tabular-nums">{formatCurrency(total)}</p>
            </div>

            {/* Body: description + line items */}
            <div class="p-5 flex-1">
              {/* Description */}
              {tier.description && (
                <p class="text-sm text-stone font-body leading-relaxed mb-5">{tier.description}</p>
              )}

              {/* Line items */}
              <table class="w-full text-sm font-body">
                {tier.lineItems.map((item) => (
                  <tr>
                    <td class="py-1.5 text-charcoal pr-4">{item.name}</td>
                    <td class="py-1.5 text-charcoal tabular-nums text-right whitespace-nowrap">{formatCurrency(item.price)}</td>
                  </tr>
                ))}
              </table>
            </div>

          </div>
        );
      })}
    </div>
  )}

  {!selectedTierKey && !isCompleted && tiers.length > 0 && (
    <TierSelectionForm
      client:load
      tiers={tiers.map((t) => ({ _key: t._key, name: t.name }))}
      projectId={projectId}
      artifactKey={artifactKey}
      columns={gridCols}
    />
  )}

  {selectedTierKey && (
    <p class="text-xs text-emerald-700 font-body mt-4 flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="20 6 9 17 4 12" /></svg>
      Tier selected: {selectedTierName}
    </p>
  )}
</section>
