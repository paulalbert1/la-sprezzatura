---
interface Appointment {
  dateTime: string;
  label: string;
}

interface ContractorData {
  name: string;
  trades: string[];
  appointments?: Appointment[];
}

interface Props {
  contractors: ContractorData[];
}

const { contractors } = Astro.props;

// Hidden entirely if no contractors
if (!contractors || contractors.length === 0) return;

const isAppointmentPast = (dt: string) => new Date(dt) < new Date();
const formatDateTime = (dt: string) =>
  new Date(dt).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
  }) + ' at ' +
  new Date(dt).toLocaleTimeString('en-US', {
    hour: 'numeric', minute: '2-digit',
  });
---

<section class="py-12 border-t border-stone-light/20">
  <h2 class="font-heading text-xl font-light text-charcoal mb-6">Contractors</h2>

  <div class="space-y-4">
    {contractors.map((c) => (
      <div class="bg-cream-dark border border-stone-light/20 p-5">
        {/* Contractor header: name + trade badges */}
        <div class="flex flex-wrap items-center gap-3 mb-1">
          <span class="text-sm text-charcoal font-body font-medium">{c.name}</span>
          {c.trades && c.trades.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {c.trades.map((trade) => (
                <span class="inline-flex px-2 py-0.5 rounded-full text-xs tracking-wide bg-stone-light/15 text-stone font-body">
                  {trade}
                </span>
              ))}
            </div>
          )}
        </div>

        {/* Appointments */}
        {c.appointments && c.appointments.length > 0 && (
          <div class="mt-3 pt-3 border-t border-stone-light/10 space-y-2">
            {c.appointments.map((apt) => {
              const past = isAppointmentPast(apt.dateTime);
              return (
                <div class:list={[
                  "flex items-baseline gap-4",
                  past && "text-stone-light line-through",
                ]}>
                  <span class:list={[
                    "text-xs font-body w-44 shrink-0 tabular-nums",
                    past ? "text-stone-light" : "text-stone",
                  ]}>
                    {formatDateTime(apt.dateTime)}
                  </span>
                  <span class:list={[
                    "text-xs font-body",
                    past ? "text-stone-light" : "text-charcoal",
                  ]}>
                    {apt.label}
                  </span>
                </div>
              );
            })}
          </div>
        )}
      </div>
    ))}
  </div>
</section>
