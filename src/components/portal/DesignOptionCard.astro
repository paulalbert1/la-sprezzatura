---
interface Props {
  option: {
    _id: string;
    blobPathname: string;
    caption: string;
    favoriteCount: number;
    commentCount: number;
    isFavorited: boolean;
  };
  index: number;
}

const { option, index } = Astro.props;
---

<article
  class="group cursor-pointer"
  data-option-index={index}
  role="button"
  aria-label={`View ${option.caption || "design option"}`}
  tabindex="0"
>
  <!-- Image container: 16:9 crop -->
  <div class="overflow-hidden aspect-[16/9] relative bg-cream-dark">
    <img
      class="w-full h-full object-cover motion-safe:transition-transform motion-safe:duration-500 motion-safe:group-hover:scale-[1.02]"
      src={`/api/blob-serve?path=${encodeURIComponent(option.blobPathname)}`}
      alt={option.caption || "Design option"}
      loading="lazy"
    />
  </div>

  <!-- Card footer -->
  <div class="flex items-center justify-between pt-3 pb-1">
    <!-- Caption -->
    <p class="text-xs text-charcoal font-body truncate flex-1 mr-3">
      {option.caption || "Untitled"}
    </p>

    <!-- Interaction indicators -->
    <div class="flex items-center gap-3">
      <!-- Heart + count -->
      <div class="flex items-center gap-1">
        {option.isFavorited ? (
          <!-- Filled heart: terracotta -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#C4836A" class="w-4 h-4" aria-hidden="true">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
          </svg>
        ) : (
          <!-- Outlined heart: stone -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#8A8478" class="w-4 h-4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        )}
        <span class="text-xs text-stone font-body">{option.favoriteCount}</span>
      </div>

      <!-- Comment count (only if > 0) -->
      {option.commentCount > 0 && (
        <div class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#8A8478" class="w-4 h-4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z" />
          </svg>
          <span class="text-xs text-stone font-body">{option.commentCount}</span>
        </div>
      )}
    </div>
  </div>
</article>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-option-index]").forEach((card) => {
      const handler = () => {
        const index = parseInt(card.getAttribute("data-option-index") || "0", 10);
        window.dispatchEvent(
          new CustomEvent("open-design-lightbox", { detail: { index } }),
        );
      };
      card.addEventListener("click", handler);
      card.addEventListener("keydown", (e) => {
        if (
          (e as KeyboardEvent).key === "Enter" ||
          (e as KeyboardEvent).key === " "
        ) {
          e.preventDefault();
          handler();
        }
      });
    });
  });
</script>
