---
import { formatCurrency } from "../../lib/formatCurrency";
import { getTrackingInfo } from "../../lib/trackingUrl";
import { PROCUREMENT_STAGES } from "../../lib/procurementStages";

interface Props {
  items: Array<{
    _key: string;
    name: string;
    status: string;
    installDate?: string;
    retailPrice?: number;
    savings?: number;
    trackingNumber?: string;
    manufacturer?: string;
    quantity?: number;
  }>;
}

const { items } = Astro.props;

// Normalize legacy "pending" status (pre-Phase 23 data) to "not-yet-ordered"
const normalized = items.map((item) => ({
  ...item,
  status: item.status === "pending" ? "not-yet-ordered" : item.status,
}));

// Chronological pipeline order: not-yet-ordered < ordered < in-transit < warehouse < delivered < installed
const STATUS_PRIORITY: Record<string, number> = {
  "not-yet-ordered": 0,
  ordered: 1,
  "in-transit": 2,
  warehouse: 3,
  delivered: 4,
  installed: 5,
};
const sorted = [...normalized].sort(
  (a, b) =>
    (STATUS_PRIORITY[a.status] ?? 99) - (STATUS_PRIORITY[b.status] ?? 99),
);
const totalSavings = normalized.reduce((sum, item) => sum + (item.savings || 0), 0);

// Derive labels from PROCUREMENT_STAGES (single source of truth)
const STATUS_LABELS: Record<string, string> = Object.fromEntries(
  PROCUREMENT_STAGES.map((s) => [s.value, s.title]),
);
const STATUS_STYLES: Record<string, string> = {
  "not-yet-ordered": "bg-stone-light/20 text-stone",
  ordered: "bg-amber-50 text-amber-700",
  "in-transit": "bg-terracotta/10 text-terracotta",
  warehouse: "bg-blue-50 text-blue-700",
  delivered: "bg-emerald-50 text-emerald-700",
  installed: "bg-emerald-100 text-emerald-800",
};

// Determine if any items have tracking info
const hasAnyTracking = normalized.some((item) => item.trackingNumber);
---

<section class="py-12 border-t border-stone-light/20">
  <h2 class="font-heading text-xl font-light text-charcoal mb-6">
    Procurement
  </h2>

  {items.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-sm text-stone font-body font-light">
        No procurement items added yet.
      </p>
      <p class="text-xs text-stone-light font-body mt-1">
        Items will appear here as they're ordered.
      </p>
    </div>
  ) : (
    <div class="overflow-x-auto -mx-6 px-6">
      <table class="w-full text-sm font-body border-collapse table-fixed">
        <caption class="sr-only">Procurement items for this project</caption>
        <colgroup>
          <col />
          <col class="w-24" />
          <col class="w-20 hidden md:table-column" />
          <col class="w-28" />
          <col class="w-28" />
          {hasAnyTracking && <col class="w-20 hidden md:table-column" />}
        </colgroup>
        <thead>
          <tr class="border-b-2 border-stone-light/30">
            <th scope="col" class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3">Item</th>
            <th scope="col" class="text-center text-xs uppercase tracking-widest text-stone font-normal pb-3">Status</th>
            <th scope="col" class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3 hidden md:table-cell">Install</th>
            <th scope="col" class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3">MSRP</th>
            <th scope="col" class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3">Savings</th>
            {hasAnyTracking && (
              <th scope="col" class="text-center text-xs uppercase tracking-widest text-stone font-normal pb-3 hidden md:table-cell">Track</th>
            )}
          </tr>
        </thead>
        <tbody>
          {sorted.map((item, index) => {
            const tracking = item.trackingNumber
              ? getTrackingInfo(item.trackingNumber)
              : null;
            return (
              <tr class:list={[
                "border-b border-stone-light/10",
                index % 2 === 1 && "bg-cream-dark/50",
              ]}>
                <td class="py-3 pr-3 text-charcoal">
                  {item.name}
                  {item.manufacturer && (
                    <span class="block text-xs text-stone mt-0.5">
                      {item.manufacturer}{item.quantity ? ` \u00B7 Qty ${item.quantity}` : ''}
                    </span>
                  )}
                </td>
                <td class="py-3 text-center">
                  <span
                    class={`inline-flex px-2 py-0.5 rounded-full text-xs tracking-wide whitespace-nowrap ${STATUS_STYLES[item.status] || "bg-stone-light/20 text-stone"}`}
                  >
                    {STATUS_LABELS[item.status] || item.status}
                  </span>
                </td>
                <td class="py-3 text-right text-stone text-xs hidden md:table-cell">
                  {item.installDate
                    ? new Date(item.installDate + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric" })
                    : "\u2014"}
                </td>
                <td class="py-3 text-right text-charcoal tabular-nums">{item.retailPrice ? formatCurrency(item.retailPrice) : "\u2014"}</td>
                <td class="py-3 text-right text-emerald-700 tabular-nums font-medium">
                  {item.savings && item.savings > 0 ? formatCurrency(item.savings) : "\u2014"}
                </td>
                {hasAnyTracking && (
                  <td class="py-3 text-center hidden md:table-cell">
                    {tracking?.url ? (
                      <a href={tracking.url} target="_blank" rel="noopener" class="text-xs text-terracotta hover:text-terracotta-light transition-colors underline underline-offset-2">{tracking.carrier.toUpperCase()}</a>
                    ) : item.trackingNumber ? (
                      <span class="text-xs text-stone">{item.trackingNumber.slice(0, 10)}...</span>
                    ) : "\u2014"}
                  </td>
                )}
              </tr>
            );
          })}
        </tbody>
      </table>

      {totalSavings > 0 && (
        <div class="mt-4 pt-3 border-t border-stone-light/30 text-right">
          <span class="text-sm font-body text-emerald-700 font-medium">
            Total savings: {formatCurrency(totalSavings)} vs. retail
          </span>
        </div>
      )}
    </div>
  )}
</section>
