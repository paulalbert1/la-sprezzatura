---
import { formatCurrency } from "../../lib/formatCurrency";
import { getTrackingInfo } from "../../lib/trackingUrl";

interface Props {
  items: Array<{
    _key: string;
    name: string;
    status: string;
    installDate?: string;
    retailPrice?: number;
    savings?: number;
    trackingNumber?: string;
  }>;
}

const { items } = Astro.props;

// Status priority sort: pending=0, ordered=1, warehouse=2, in-transit=3, delivered=4, installed=5
const STATUS_PRIORITY: Record<string, number> = {
  pending: 0,
  ordered: 1,
  warehouse: 2,
  "in-transit": 3,
  delivered: 4,
  installed: 5,
};
const sorted = [...items].sort(
  (a, b) =>
    (STATUS_PRIORITY[a.status] ?? 99) - (STATUS_PRIORITY[b.status] ?? 99),
);
const totalSavings = items.reduce((sum, item) => sum + (item.savings || 0), 0);

const STATUS_LABELS: Record<string, string> = {
  pending: "Pending",
  ordered: "Ordered",
  warehouse: "Warehouse",
  "in-transit": "In Transit",
  delivered: "Delivered",
  installed: "Installed",
};
const STATUS_STYLES: Record<string, string> = {
  pending: "bg-stone-light/20 text-stone",
  ordered: "bg-terracotta/10 text-terracotta",
  warehouse: "bg-terracotta/10 text-terracotta",
  "in-transit": "bg-terracotta/10 text-terracotta",
  delivered: "bg-emerald-50 text-emerald-700",
  installed: "bg-emerald-50 text-emerald-700",
};
---

<section class="py-12 border-t border-stone-light/20">
  <h2 class="font-heading text-xl font-light text-charcoal mb-6">
    Procurement
  </h2>

  {items.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-sm text-stone font-body font-light">
        No procurement items added yet.
      </p>
      <p class="text-xs text-stone-light font-body mt-1">
        Items will appear here as they're ordered.
      </p>
    </div>
  ) : (
    <div class="overflow-x-auto -mx-6 px-6">
      <table class="w-full text-sm font-body">
        <caption class="sr-only">Procurement items for this project</caption>
        <thead>
          <tr class="border-b border-stone-light/20">
            <th
              scope="col"
              class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3"
            >
              Item
            </th>
            <th
              scope="col"
              class="text-center text-xs uppercase tracking-widest text-stone font-normal pb-3 w-[120px]"
            >
              Status
            </th>
            <th
              scope="col"
              class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3 w-[100px] hidden md:table-cell"
            >
              Install Date
            </th>
            <th
              scope="col"
              class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3 w-[100px]"
            >
              MSRP
            </th>
            <th
              scope="col"
              class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3 w-[100px]"
            >
              Savings
            </th>
            <th
              scope="col"
              class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3 w-[100px] hidden md:table-cell"
            >
              Tracking
            </th>
          </tr>
        </thead>
        <tbody>
          {sorted.map((item) => {
            const tracking = item.trackingNumber
              ? getTrackingInfo(item.trackingNumber)
              : null;
            return (
              <tr class="border-b border-stone-light/10">
                <td class="py-3 text-charcoal">{item.name}</td>
                <td class="py-3 text-center">
                  <span
                    class={`inline-flex px-3 py-1 rounded-full text-xs tracking-wide ${STATUS_STYLES[item.status] || "bg-stone-light/20 text-stone"}`}
                  >
                    {STATUS_LABELS[item.status] || item.status}
                  </span>
                </td>
                <td class="py-3 text-stone hidden md:table-cell">
                  {item.installDate
                    ? new Date(
                        item.installDate + "T00:00:00",
                      ).toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                      })
                    : "\u2014"}
                </td>
                <td class="py-3 text-right text-charcoal">
                  {item.retailPrice ? formatCurrency(item.retailPrice) : "\u2014"}
                </td>
                <td class="py-3 text-right text-emerald-700">
                  {item.savings && item.savings > 0
                    ? formatCurrency(item.savings)
                    : "\u2014"}
                </td>
                <td class="py-3 hidden md:table-cell">
                  {tracking?.url ? (
                    <a
                      href={tracking.url}
                      target="_blank"
                      rel="noopener"
                      class="text-xs text-terracotta hover:text-terracotta-light transition-colors underline underline-offset-2"
                    >
                      {tracking.carrier.toUpperCase()}
                    </a>
                  ) : item.trackingNumber ? (
                    <span class="text-xs text-stone">
                      {item.trackingNumber.slice(0, 10)}...
                    </span>
                  ) : (
                    "\u2014"
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>

      {totalSavings > 0 && (
        <div class="mt-4 text-right">
          <span class="text-sm font-body text-emerald-700">
            You saved {formatCurrency(totalSavings)} vs. retail
          </span>
        </div>
      )}
    </div>
  )}
</section>
