---
import { formatCurrency } from "../../lib/formatCurrency";
import { getTrackingInfo } from "../../lib/trackingUrl";

interface Props {
  items: Array<{
    _key: string;
    name: string;
    status: string;
    installDate?: string;
    retailPrice?: number;
    savings?: number;
    trackingNumber?: string;
  }>;
}

const { items } = Astro.props;

// Status priority sort: pending=0, ordered=1, warehouse=2, in-transit=3, delivered=4, installed=5
const STATUS_PRIORITY: Record<string, number> = {
  pending: 0,
  ordered: 1,
  warehouse: 2,
  "in-transit": 3,
  delivered: 4,
  installed: 5,
};
const sorted = [...items].sort(
  (a, b) =>
    (STATUS_PRIORITY[a.status] ?? 99) - (STATUS_PRIORITY[b.status] ?? 99),
);
const totalSavings = items.reduce((sum, item) => sum + (item.savings || 0), 0);

const STATUS_LABELS: Record<string, string> = {
  pending: "Pending",
  ordered: "Ordered",
  warehouse: "Warehouse",
  "in-transit": "In Transit",
  delivered: "Delivered",
  installed: "Installed",
};
const STATUS_STYLES: Record<string, string> = {
  pending: "bg-stone-light/20 text-stone",
  ordered: "bg-amber-50 text-amber-700",
  warehouse: "bg-blue-50 text-blue-700",
  "in-transit": "bg-terracotta/10 text-terracotta",
  delivered: "bg-emerald-50 text-emerald-700",
  installed: "bg-emerald-100 text-emerald-800",
};

// Determine if any items have tracking info
const hasAnyTracking = items.some((item) => item.trackingNumber);
---

<section class="py-12 border-t border-stone-light/20">
  <h2 class="font-heading text-xl font-light text-charcoal mb-6">
    Procurement
  </h2>

  {items.length === 0 ? (
    <div class="text-center py-8">
      <p class="text-sm text-stone font-body font-light">
        No procurement items added yet.
      </p>
      <p class="text-xs text-stone-light font-body mt-1">
        Items will appear here as they're ordered.
      </p>
    </div>
  ) : (
    <div class="overflow-x-auto -mx-6 px-6">
      <table class="w-full text-sm font-body border-collapse">
        <caption class="sr-only">Procurement items for this project</caption>
        <thead>
          <tr class="border-b-2 border-stone-light/30">
            <th
              scope="col"
              class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3 pr-4"
            >
              Item
            </th>
            <th
              scope="col"
              class="text-center text-xs uppercase tracking-widest text-stone font-normal pb-3 px-2 w-[110px]"
            >
              Status
            </th>
            <th
              scope="col"
              class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3 px-2 w-[90px] hidden md:table-cell"
            >
              Install
            </th>
            <th
              scope="col"
              class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3 px-2 w-[100px]"
            >
              MSRP
            </th>
            <th
              scope="col"
              class="text-right text-xs uppercase tracking-widest text-stone font-normal pb-3 pl-2 w-[100px]"
            >
              Savings
            </th>
            {hasAnyTracking && (
              <th
                scope="col"
                class="text-left text-xs uppercase tracking-widest text-stone font-normal pb-3 pl-3 w-[90px] hidden md:table-cell"
              >
                Tracking
              </th>
            )}
          </tr>
        </thead>
        <tbody>
          {sorted.map((item, index) => {
            const tracking = item.trackingNumber
              ? getTrackingInfo(item.trackingNumber)
              : null;
            return (
              <tr class:list={[
                "border-b border-stone-light/10",
                index % 2 === 1 && "bg-cream-dark/50",
              ]}>
                <td class="py-3 pr-4 text-charcoal">{item.name}</td>
                <td class="py-3 px-2 text-center">
                  <span
                    class={`inline-flex px-2.5 py-0.5 rounded-full text-xs tracking-wide whitespace-nowrap ${STATUS_STYLES[item.status] || "bg-stone-light/20 text-stone"}`}
                  >
                    {STATUS_LABELS[item.status] || item.status}
                  </span>
                </td>
                <td class="py-3 px-2 text-stone text-xs hidden md:table-cell">
                  {item.installDate
                    ? new Date(
                        item.installDate + "T00:00:00",
                      ).toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                      })
                    : "\u2014"}
                </td>
                <td class="py-3 px-2 text-right text-charcoal tabular-nums">
                  {item.retailPrice ? formatCurrency(item.retailPrice) : "\u2014"}
                </td>
                <td class="py-3 pl-2 text-right text-emerald-700 tabular-nums">
                  {item.savings && item.savings > 0
                    ? formatCurrency(item.savings)
                    : "\u2014"}
                </td>
                {hasAnyTracking && (
                  <td class="py-3 pl-3 hidden md:table-cell">
                    {tracking?.url ? (
                      <a
                        href={tracking.url}
                        target="_blank"
                        rel="noopener"
                        class="text-xs text-terracotta hover:text-terracotta-light transition-colors underline underline-offset-2"
                      >
                        {tracking.carrier.toUpperCase()}
                      </a>
                    ) : item.trackingNumber ? (
                      <span class="text-xs text-stone">
                        {item.trackingNumber.slice(0, 10)}...
                      </span>
                    ) : (
                      "\u2014"
                    )}
                  </td>
                )}
              </tr>
            );
          })}
        </tbody>
      </table>

      {totalSavings > 0 && (
        <div class="mt-4 pt-3 border-t border-stone-light/30 text-right">
          <span class="text-sm font-body text-emerald-700 font-medium">
            Total savings: {formatCurrency(totalSavings)} vs. retail
          </span>
        </div>
      )}
    </div>
  )}
</section>
