---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  type = "website",
  noindex = true, // true for staging -- set to false after Phase 4 DNS cutover
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.href;

const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : Astro.site
    ? new URL(ogImage, Astro.site).toString()
    : ogImage;
---

<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="La Sprezzatura Interior Design" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
