---
import SanityImage from "../SanityImage.astro";

interface Props {
  project: {
    _id: string;
    title: string;
    slug: { current: string };
    heroImage?: any;
    roomType?: string;
    style?: string;
    location?: string;
  };
}

const { project } = Astro.props;
---

<article
  data-project-card
  data-room={project.roomType ?? ""}
  data-style={project.style ?? ""}
  class="project-card"
  data-animate="fade-up"
>
  <a
    href={`/portfolio/${project.slug.current}`}
    class="group block"
    aria-label={`View ${project.title} project`}
  >
    <div class="overflow-hidden aspect-[4/3] relative bg-cream-dark">
      {
        project.heroImage ? (
          <SanityImage
            image={project.heroImage}
            alt={project.title}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 600px"
            widths={[400, 640, 800]}
            class="w-full h-full transition-transform duration-700 ease-out group-hover:scale-[1.03]"
          />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-cream-dark to-stone-light/50" />
        )
      }
    </div>
    <div class="pt-5 pb-2">
      {
        project.roomType && (
          <p class="text-xs uppercase tracking-widest text-stone mb-2 font-body">
            {project.roomType}
          </p>
        )
      }
      <h2
        class="font-heading text-2xl md:text-3xl font-light text-charcoal leading-tight group-hover:text-terracotta transition-colors duration-300"
      >
        {project.title}
      </h2>
      {
        project.location && (
          <p class="text-sm text-stone mt-1.5 font-body">{project.location}</p>
        )
      }
    </div>
  </a>
</article>
