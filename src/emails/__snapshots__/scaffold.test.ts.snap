exports[`Scaffold (Phase 45 proof-of-pipeline) > renders deterministic HTML (snapshot) 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:rgb(250,248,245)"><!--$--><!--html--><!--head--><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:rgb(250,248,245);font-family:&quot;DM Sans&quot;,&quot;system-ui&quot;,sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:36rem;margin-right:auto;margin-left:auto;padding-bottom:40px;padding-top:40px;padding-right:20px;padding-left:20px"><tbody><tr style="width:100%"><td><h1 style="font-size:24px;line-height:32px;color:rgb(44,41,38);font-family:&quot;Cormorant Garamond&quot;,&quot;Georgia&quot;,serif">Hello, Sample Recipient</h1><p class="text-charcoal-light" style="font-size:16px;line-height:28px;margin-top:16px;margin-bottom:16px">Brand-token round-trip works.</p><a href="https://lasprezz.com" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:rgb(196,131,106);color:rgb(255,255,255);padding-right:24px;padding-left:24px;padding-bottom:12px;padding-top:12px;text-decoration-line:none" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:18" hidden>&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:9px">View</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;
