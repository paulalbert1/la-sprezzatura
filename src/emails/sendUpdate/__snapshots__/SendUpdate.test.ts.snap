x;font-weight:600;border-radius:2px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:20.4" hidden>&#8202;&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:10.2px">Open Portal</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a><p style="font-size:12px;line-height:20px;color:#8A8478;margin:0;margin-top:14px;margin-bottom:0;margin-left:0;margin-right:0">You can reply to this email directly.</p></td></tr></tbody></table><hr class="border-cream-dark" style="width:100%;border:none;border-top:1px solid #eaeaea;margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-right:40px;padding-left:40px;padding-bottom:16px;padding-top:16px;text-align:center"><tbody><tr><td><p class="text-stone-light" style="font-size:10px;line-height:24px;letter-spacing:0.06em;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">Elizabeth Lewis<!-- --> <!-- -->·<!-- --> <!-- -->Darien, CT</p><p class="text-stone-light" style="font-size:10px;line-height:24px;letter-spacing:0.06em;margin:0;margin-top:8px;margin-bottom:0;margin-left:0;margin-right:0">Sent via Sprezza Hub</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"
