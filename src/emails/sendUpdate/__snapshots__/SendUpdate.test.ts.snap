06em">Delivered</span></td><td width="18%" align="left" data-id="__react-email-column" style="vertical-align:top"><span style="font-size:13px;color:#4A4540;letter-spacing:0.02em">Apr 21</span></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-left:40px;padding-right:40px;padding-top:8px;padding-bottom:32px"><tbody><tr><td><a href="https://lasprezz.com/portal/client/abc123" class="cta-terracotta" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:#C4836A;color:#FAF8F5;padding-top:13.6px;padding-bottom:13.6px;padding-left:32px;padding-right:32px;letter-spacing:0.14em;text-transform:uppercase;font-size:11px;font-weight:600;border-radius:2px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:20.4" hidden>&#8202;&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:10.2px">Open Portal</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a><p style="font-size:12px;line-height:20px;color:#8A8478;margin:0;margin-top:14px;margin-bottom:0;margin-left:0;margin-right:0">You can reply to this email directly.</p></td></tr></tbody></table><hr class="border-cream-dark" style="width:100%;border:none;border-top:1px solid #eaeaea;margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-right:40px;padding-left:40px;padding-bottom:16px;padding-top:16px;text-align:center"><tbody><tr><td><p class="text-stone-light" style="font-size:10px;line-height:24px;letter-spacing:0.06em;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">Elizabeth Lewis<!-- --> <!-- -->·<!-- --> <!-- -->Darien, CT</p><p class="text-stone-light" 