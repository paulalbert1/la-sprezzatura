exports[`SendUpdate (Phase 46-04 redesign) > snapshot: noBody 1`] = `
"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/><meta name="color-scheme" content="only light"/><meta name="supported-color-schemes" content="light"/><style>
              /* Body bg (body element selector) */
              [data-ogsb] body { background-color: #FAF8F5 !important; }

              /* CTA backgrounds (hand-written -- only 2 variants) */
              [data-ogsb] .cta-terracotta { background-color: #C4836A !important; }
              [data-ogsb] .cta-gold { background-color: #9A7B4B !important; }

              /* Procurement pill backgrounds -- generated from STATUS_PILL_STYLES (D-18 IN-R3-02) */
              [data-ogsb] .pill-scheduled { background-color: #F3EFE9 !important; }
              [data-ogsb] .pill-warehouse { background-color: #F3EDE3 !important; }
              [data-ogsb] .pill-in-transit { background-color: #FBF2E2 !important; }
              [data-ogsb] .pill-ordered { background-color: #E8F0F9 !important; }
              [data-ogsb] .pill-pending { background-color: #FDEEE6 !important; }
              [data-ogsb] .pill-delivered { background-color: #EDF5E8 !important; }
              [data-ogsb] .pill-installed { background-color: #EDF5E8 !important; }

              /* Procurement pill text -- generated from STATUS_PILL_STYLES (D-18 IN-R3-02).
                 Bind via className on the pill <span> (D-15). Tailwind utility .text- and
                 .border-cream-dark rules previously here are DELETED per 46.1 D-16 -- they
                 targeted className hooks Tailwind compiles + strips, so they never bound.
                 The universal-selector catch-all is also DELETED per 46.1 D-17 -- it
                 actively cancelled every inline color in dark mode. */
              [data-ogsc] .pill-scheduled { color: #6B5E52 !important; }
              [data-ogsc] .pill-warehouse { color: #6B5E52 !important; }
              [data-ogsc] .pill-in-transit { color: #8A5E1A !important; }
              [data-ogsc] .pill-ordered { color: #2A5485 !important; }
              [data-ogsc] .pill-pending { color: #9B3A2A !important; }
              [data-ogsc] .pill-delivered { color: #3A6620 !important; }
              [data-ogsc] .pill-installed { color: #3A6620 !important; }

              /* Procurement pill borders -- generated from STATUS_PILL_STYLES (D-18 IN-R3-02).
                 Outlook auto-darken treats border as text-adjacent, so [data-ogsc] is the
                 correct hook (not [data-ogsb]). */
              [data-ogsc] .pill-scheduled { border-color: #E0D5C5 !important; }
              [data-ogsc] .pill-warehouse { border-color: #D4C8B8 !important; }
              [data-ogsc] .pill-in-transit { border-color: #E8CFA0 !important; }
              [data-ogsc] .pill-ordered { border-color: #B0CAE8 !important; }
              [data-ogsc] .pill-pending { border-color: #F2C9B8 !important; }
              [data-ogsc] .pill-delivered { border-color: #C4DBA8 !important; }
              [data-ogsc] .pill-installed { border-color: #A8C98C !important; }

              /* gap-7 (46.1 D-10/D-11) -- candidate (b) prefers-color-scheme media query
                 per .planning/phases/46.1-merge-gate-gap-closure/46.1-SPIKE-OUTLOOK-MAC.md
                 Recommendation. ADDITIVE on top of the [data-ogsc]/[data-ogsb] block above.
                 Re-pins the locked light palette so any Outlook variant honoring
                 prefers-color-scheme keeps cream bg + dark text in dark mode. Pill rules
                 generated from STATUS_PILL_STYLES (single source of truth). !important is
                 required for source-order specificity tie-resolution against any
                 Outlook-Mac-injected dark-mode rule. */
              @media (prefers-color-scheme: dark) {
                body { background-color: #FAF8F5 !important; }
                .cta-terracotta { background-color: #C4836A !important; }
                .cta-gold { background-color: #9A7B4B !important; }
                .pill-scheduled { background-color: #F3EFE9 !important; color: #6B5E52 !important; border-color: #E0D5C5 !important; }
              .pill-warehouse { background-color: #F3EDE3 !important; color: #6B5E52 !important; border-color: #D4C8B8 !important; }
              .pill-in-transit { background-color: #FBF2E2 !important; color: #8A5E1A !important; border-color: #E8CFA0 !important; }
              .pill-ordered { background-color: #E8F0F9 !important; color: #2A5485 !important; border-color: #B0CAE8 !important; }
              .pill-pending { background-color: #FDEEE6 !important; color: #9B3A2A !important; border-color: #F2C9B8 !important; }
              .pill-delivered { background-color: #EDF5E8 !important; color: #3A6620 !important; border-color: #C4DBA8 !important; }
              .pill-installed { background-color: #EDF5E8 !important; color: #3A6620 !important; border-color: #A8C98C !important; }
              }
            </style></head><body style="background-color:#FAF8F5"><!--$--><!--html--><!--head--><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:#FAF8F5;font-family:&quot;DM Sans&quot;,&quot;system-ui&quot;,sans-serif"><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Project update for Kimball Residence — one approval needed by May 9.<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><div><!--[if mso]><style>body { mso-color-scheme: light !important; }</style><![endif]--></div><table bgcolor="#FAF8F5" width="100%" cellPadding="0" cellSpacing="0" border="0" role="presentation" style="background-color:#FAF8F5"><tbody><tr><td align="center" valign="top" style="background-color:#FAF8F5"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:580px;margin-right:auto;margin-left:auto"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-right:40px;padding-left:40px;padding-top:32px;padding-bottom:24px"><tbody><tr><td><p style="font-size:11.5px;line-height:24px;letter-spacing:0.14em;color:rgb(138,132,120);text-transform:uppercase;font-weight:600;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">LA SPREZZATURA</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-left:40px;padding-right:40px;padding-top:8px;padding-bottom:12px"><tbody><tr><td><h1 style="font-size:22px;font-family:&quot;Cormorant Garamond&quot;,&quot;Georgia&quot;,serif;color:#2C2926;margin:0;margin-bottom:6px;font-weight:600;letter-spacing:-0.005em">Project Update</h1><p style="font-size:13px;line-height:24px;color:#8A8478;margin:0;margin-bottom:24px;letter-spacing:0.04em;margin-top:0;margin-left:0;margin-right:0">Kimball Residence<!-- --> <!-- -->·<!-- --> <!-- -->April 27, 2026</p><p style="font-size:15px;line-height:28px;color:#4A4540;margin:0;margin-bottom:14px;margin-top:0;margin-left:0;margin-right:0">Hi Sarah,</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-left:40px;padding-right:40px;padding-bottom:24px;padding-top:8px"><tbody><tr><td><p style="font-size:10px;line-height:24px;letter-spacing:0.14em;color:#8A8478;text-transform:uppercase;font-weight:600;margin:0;margin-bottom:12px;margin-top:0;margin-left:0;margin-right:0">For your review</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="border-bottom:0.5px solid #E8DDD0;padding-top:12px;padding-bottom:12px;vertical-align:middle"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column" style="vertical-align:middle"><span style="display:inline-block;width:7px;height:7px;background-color:#C4836A;margin-right:12px;vertical-align:middle"></span><span style="font-size:14px;color:#2C2926;vertical-align:middle">Approve the floor plan</span></td><td align="right" data-id="__react-email-column" style="vertical-align:middle"><span style="font-size:13px;color:#4A4540;letter-spacing:0.02em">Due May 9</span></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="border-bottom:0.5px solid #E8DDD0;padding-top:12px;padding-bottom:12px;vertical-align:middle"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column" style="vertical-align:middle"><span style="display:inline-block;width:7px;height:7px;background-color:#C4836A;margin-right:12px;vertical-align:middle"></span><span style="font-size:14px;color:#2C2926;vertical-align:middle">Review the lighting proposal</span></td><td align="right" data-id="__react-email-column" style="vertical-align:middle"><span style="font-size:13px;color:#4A4540;letter-spacing:0.02em">No deadline</span></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="border-bottom:0.5px solid #E8DDD0;padding-top:12px;padding-bottom:12px;vertical-align:middle"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column" style="vertical-align:middle"><span style="display:inline-block;width:7px;height:7px;background-color:#C4836A;margin-right:12px;vertical-align:middle"></span><span style="font-size:14px;color:#2C2926;vertical-align:middle">Proposal</span></td><td align="right" data-id="__react-email-column" style="vertical-align:middle"></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="border-bottom:0.5px solid #E8DDD0;padding-top:12px;padding-bottom:12px;vertical-align:middle"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column" style="vertical-align:middle"><span style="display:inline-block;width:7px;height:7px;background-color:#C4836A;margin-right:12px;vertical-align:middle"></span><span style="font-size:14px;color:#2C2926;vertical-align:middle">Design Board</span></td><td align="right" data-id="__react-email-column" style="vertical-align:middle"></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border=