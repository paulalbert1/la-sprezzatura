---
import { Font } from "astro:assets";
import "../styles/global.css";
import AdminNav from "../components/admin/AdminNav.tsx";
import { getTenantById } from "../lib/tenants";

export const prerender = false;

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  pageTitle: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, pageTitle, breadcrumbs } = Astro.props;
const currentPath = Astro.url.pathname;

const tenantId = Astro.locals.tenantId;
const tenant = tenantId ? getTenantById(tenantId) : undefined;
const businessName = tenant?.businessName ?? "Studio";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-body" preload />
    <title>{title}</title>
  </head>
  <body class="min-h-screen" style="background-color: #FAF7F2; color: #2C2520; font-family: var(--font-sans);">
    {/* Sidebar - fixed, full height, collapsible */}
    <aside
      id="admin-sidebar"
      class="fixed left-0 top-0 h-screen w-60 py-8 z-10 transition-all duration-200 overflow-hidden"
      style="background-color: #FFFEFB; border-right: 0.5px solid #E8DDD0;"
    >
      <AdminNav client:load currentPath={currentPath} businessName={businessName} />
    </aside>

    {/* Main area - offset by sidebar width */}
    <div id="admin-main" class="ml-60 min-h-screen flex flex-col transition-all duration-200">
      {/* Top bar -- same bg as body, no border, breadcrumb + collapse button only */}
      <header class="px-7 pt-5 pb-1 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <button
            type="button"
            id="sidebar-toggle"
            aria-label="Collapse sidebar"
            class="p-1 rounded-md hover:bg-[#F3EDE3] transition-colors"
            style="color: #9E8E80;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
            </svg>
          </button>
          {breadcrumbs && breadcrumbs.length > 0 ? (
            <nav aria-label="Breadcrumb">
              <ol class="flex items-center" style="font-size: 11.5px; letter-spacing: 0.03em;">
                {breadcrumbs.map((item, index) => (
                  <>
                    {index > 0 && <li aria-hidden="true"><span class="mx-2" style="color: #9E8E80;">/</span></li>}
                    <li>
                      {item.href ? (
                        <a href={item.href} class="transition-colors hover:text-[#9A7B4B]" style="color: #9E8E80;">{item.label}</a>
                      ) : (
                        <span aria-current="page" style="color: #2C2520;">{item.label}</span>
                      )}
                    </li>
                  </>
                ))}
              </ol>
            </nav>
          ) : (
            <h1 class="text-[22px] font-semibold text-charcoal" style="font-family: var(--font-body); letter-spacing: 0;">{pageTitle}</h1>
          )}
        </div>
      </header>

      {/* Content area */}
      <main class="flex-1 px-7 py-6">
        <slot />
      </main>
    </div>

    <script is:inline>
      (function () {
        const sidebar = document.getElementById("admin-sidebar");
        const main = document.getElementById("admin-main");
        const toggle = document.getElementById("sidebar-toggle");
        if (!sidebar || !main || !toggle) return;

        const STORAGE_KEY = "admin_sidebar_collapsed";
        const collapsed = localStorage.getItem(STORAGE_KEY) === "true";

        function apply(isCollapsed) {
          if (isCollapsed) {
            sidebar.style.transform = "translateX(-100%)";
            main.classList.remove("ml-60");
            main.classList.add("ml-0");
          } else {
            sidebar.style.transform = "translateX(0)";
            main.classList.remove("ml-0");
            main.classList.add("ml-60");
          }
        }

        apply(collapsed);

        toggle.addEventListener("click", () => {
          const isNowCollapsed = !(localStorage.getItem(STORAGE_KEY) === "true");
          localStorage.setItem(STORAGE_KEY, String(isNowCollapsed));
          apply(isNowCollapsed);
        });
      })();
    </script>
  </body>
</html>
