---
import { Font } from "astro:assets";
import "../styles/global.css";
import AdminNav from "../components/admin/AdminNav.tsx";

export const prerender = false;

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  pageTitle: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, pageTitle, breadcrumbs } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-body" preload />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-charcoal font-body min-h-screen">
    {/* Sidebar - fixed, full height, 240px wide (per D-07) */}
    <aside class="fixed left-0 top-0 h-screen w-60 bg-cream-dark border-r border-stone-light/30 px-6 py-12 z-10">
      <AdminNav client:load currentPath={currentPath} />
    </aside>

    {/* Main area - offset by sidebar width */}
    <div class="ml-60 min-h-screen flex flex-col">
      {/* Top bar (per D-10) */}
      <header class="bg-cream border-b border-stone-light/30 px-6 py-4 flex items-center justify-between">
        {breadcrumbs && breadcrumbs.length > 0 ? (
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center">
              {breadcrumbs.map((item, index) => (
                <>
                  {index > 0 && <li aria-hidden="true"><span class="text-stone-light mx-2">/</span></li>}
                  <li>
                    {item.href ? (
                      <a href={item.href} class="text-sm text-stone hover:text-terracotta transition-colors font-body">{item.label}</a>
                    ) : (
                      <span class="text-sm text-charcoal font-body" aria-current="page">{item.label}</span>
                    )}
                  </li>
                </>
              ))}
            </ol>
          </nav>
        ) : (
          <h1 class="text-xl font-semibold font-body text-charcoal">{pageTitle}</h1>
        )}
        <a
          href="/admin/logout"
          class="text-sm text-stone hover:text-charcoal transition-colors font-body"
        >
          Log out
        </a>
      </header>

      {/* Content area */}
      <main class="flex-1 px-8 py-8">
        <slot />
      </main>
    </div>
  </body>
</html>
