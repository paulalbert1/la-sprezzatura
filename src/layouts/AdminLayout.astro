---
import { Font } from "astro:assets";
import "../styles/global.css";
import AdminNav from "../components/admin/AdminNav.tsx";
import { getTenantById } from "../lib/tenants";

export const prerender = false;

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  pageTitle: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, pageTitle, breadcrumbs } = Astro.props;
const currentPath = Astro.url.pathname;

const tenantId = Astro.locals.tenantId;
const tenant = tenantId ? getTenantById(tenantId) : undefined;
const businessName = tenant?.businessName ?? "Studio";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-body" preload />
    <title>{title}</title>
  </head>
  <body class="min-h-screen" style="background-color: #FAF7F2; color: #2C2520; font-family: var(--font-sans);">
    {/* Sidebar - fixed, full height, 240px wide */}
    <aside class="fixed left-0 top-0 h-screen w-60 px-6 py-12 z-10" style="background-color: #FFFEFB; border-right: 0.5px solid #E8DDD0;">
      <AdminNav client:load currentPath={currentPath} businessName={businessName} />
    </aside>

    {/* Main area - offset by sidebar width */}
    <div class="ml-60 min-h-screen flex flex-col">
      {/* Top bar */}
      <header class="px-8 pt-4 flex items-start justify-between" style="background-color: #FAF7F2;">
        {breadcrumbs && breadcrumbs.length > 0 ? (
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center">
              {breadcrumbs.map((item, index) => (
                <>
                  {index > 0 && <li aria-hidden="true"><span class="text-stone-light mx-2">/</span></li>}
                  <li>
                    {item.href ? (
                      <a href={item.href} class="text-sm text-stone hover:text-terracotta transition-colors font-body">{item.label}</a>
                    ) : (
                      <span class="text-sm text-charcoal font-body" aria-current="page">{item.label}</span>
                    )}
                  </li>
                </>
              ))}
            </ol>
          </nav>
        ) : (
          <h1 class="text-[22px] font-semibold text-charcoal" style="font-family: var(--font-body); letter-spacing: 0; margin-left: 5px; margin-top: 20px;">{pageTitle}</h1>
        )}
        <a
          href="/admin/logout"
          class="text-xs text-stone hover:text-charcoal transition-colors font-body mt-1"
        >
          Log out
        </a>
      </header>

      {/* Content area */}
      <main class="flex-1 px-8 py-8">
        <slot />
      </main>
    </div>
  </body>
</html>
