---
import { Font } from "astro:assets";
import "../styles/global.css";
import SEOHead from "../components/seo/SEOHead.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import Header from "../components/layout/Header.astro";
import MobileMenu from "../components/layout/MobileMenu.astro";
import Footer from "../components/layout/Footer.astro";
import ScrollAnimations from "../components/animations/ScrollAnimations.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  transparentHeader?: boolean;
}

const {
  title,
  description = "Luxury interior design studio serving Long Island and New York City. Creating spaces that feel effortlessly beautiful.",
  ogImage,
  noindex = true,
  transparentHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-body" preload />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
    />
    <JsonLd />
  </head>
  <body class="bg-cream text-charcoal font-body min-h-screen flex flex-col">
    <Header transparent={transparentHeader} />
    <MobileMenu />
    <main class:list={[transparentHeader ? "" : "pt-16 md:pt-20"]}>
      <slot />
    </main>
    <Footer />
    <ScrollAnimations />
  </body>
</html>
