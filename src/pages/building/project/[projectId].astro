---
export const prerender = false;

import PortalLayout from "../../../components/portal/PortalLayout.astro";
import ConfidentialityBanner from "../../../components/portal/ConfidentialityBanner.astro";
import ExpirationBadge from "../../../components/portal/ExpirationBadge.astro";
import {
  getBuildingManagerProject,
  getSiteContactInfo,
} from "../../../sanity/queries";
import { sanityClient } from "sanity:client";
import { getPortalBrand } from "../../../lib/portal/portalBrand";

const tenant = await getPortalBrand(sanityClient);

// buildingManagerEmail injected by middleware (guaranteed by auth guard)
const email = Astro.locals.buildingManagerEmail!;

// Get projectId from dynamic route param
const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/building/dashboard");
}

// Fetch building manager project detail (scoped to this email)
const project = await getBuildingManagerProject(projectId, email);
if (!project) {
  return Astro.redirect("/building/dashboard");
}

// Fetch site contact info for Contact Liz section
const siteContact = await getSiteContactInfo();

// Format project address
const addressStr = [
  project.projectAddress?.street,
  project.projectAddress?.city,
  project.projectAddress?.state,
  project.projectAddress?.zip,
]
  .filter(Boolean)
  .join(", ");
---

<PortalLayout title={`${project.title} | Building Portal | ${tenant.displayName}`} tenant={tenant}>
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 py-12 md:py-20">
      <a href="/building/dashboard" class="inline-flex items-center gap-1 text-xs text-stone hover:text-terracotta transition-colors uppercase tracking-widest font-body mb-6">
        <span>&larr;</span> Back to Dashboard
      </a>

      {/* Page header */}
      <h1 class="text-3xl md:text-4xl font-heading font-light text-charcoal text-center mb-2">
        {project.title}
      </h1>
      {addressStr && (
        <p class="text-sm text-stone font-body text-center mb-8">
          {addressStr}
        </p>
      )}

      <ConfidentialityBanner />

      {/* Section: Client Contact */}
      <section class="py-12 border-t border-stone-light/20">
        <h2 class="font-heading text-xl font-light text-charcoal mb-6">
          Client Contact
        </h2>
        <div class="bg-cream-dark border border-stone-light/20 rounded-lg p-6">
          {project.primaryClient?.name && (
            <p class="text-base text-charcoal font-body font-medium mb-2">
              {project.primaryClient.name}
            </p>
          )}
          {project.primaryClient?.email && (
            <a
              href={"mailto:" + project.primaryClient.email}
              class="block text-sm text-charcoal hover:text-terracotta transition-colors font-body mb-1"
            >
              {project.primaryClient.email}
            </a>
          )}
          {project.primaryClient?.phone && (
            <a
              href={"tel:" + project.primaryClient.phone}
              class="block text-sm text-charcoal hover:text-terracotta transition-colors font-body"
            >
              {project.primaryClient.phone}
            </a>
          )}
        </div>
      </section>

      {/* Section: Certificates of Insurance */}
      <section class="py-12 border-t border-stone-light/20">
        <h2 class="font-heading text-xl font-light text-charcoal mb-6">
          Certificates of Insurance
        </h2>
        {(project.cois || []).length > 0 ? (
          <div class="space-y-4">
            {project.cois.map((coi: any) => (
              <div class="bg-cream-dark border border-stone-light/20 rounded-lg p-5">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-sm text-charcoal font-body font-medium">{coi.issuerName}</span>
                  <ExpirationBadge expirationDate={coi.expirationDate} />
                </div>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-3">
                  {coi.coverageType && (
                    <span class="text-sm text-stone font-body">{coi.coverageType}</span>
                  )}
                  {coi.policyNumber && (
                    <span class="text-sm text-stone font-body">Policy: {coi.policyNumber}</span>
                  )}
                </div>
                {coi.expirationDate && (
                  <p class="text-sm text-stone font-body mb-3">
                    Expires {new Date(coi.expirationDate + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                  </p>
                )}
                {coi.file && (
                  <a
                    href={"/api/blob-serve?path=" + encodeURIComponent(coi.file)}
                    class="text-sm text-terracotta underline hover:text-terracotta-light transition-colors font-body"
                  >
                    Download Certificate
                  </a>
                )}
              </div>
            ))}
          </div>
        ) : (
          <p class="text-sm text-stone font-body">
            No certificates of insurance have been uploaded yet.
          </p>
        )}
      </section>

      {/* Section: Legal Documents */}
      <section class="py-12 border-t border-stone-light/20">
        <h2 class="font-heading text-xl font-light text-charcoal mb-6">
          Legal Documents
        </h2>
        {(project.legalDocs || []).length > 0 ? (
          <div class="space-y-4">
            {project.legalDocs.map((doc: any) => (
              <div class="bg-cream-dark border border-stone-light/20 rounded-lg p-5">
                <div class="flex items-center justify-between">
                  <div>
                    <span class="text-sm text-charcoal font-body font-medium">{doc.documentName}</span>
                    {doc.description && (
                      <p class="text-sm text-stone font-body mt-1">{doc.description}</p>
                    )}
                  </div>
                  {doc.file && (
                    <a
                      href={"/api/blob-serve?path=" + encodeURIComponent(doc.file)}
                      class="text-sm text-terracotta underline hover:text-terracotta-light transition-colors font-body shrink-0 ml-4"
                    >
                      Download Document
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-sm text-stone font-body">
            No legal documents uploaded yet.
          </p>
        )}
      </section>

      {/* Section: Contractors */}
      <section class="py-12 border-t border-stone-light/20">
        <h2 class="font-heading text-xl font-light text-charcoal mb-6">
          Contractors
        </h2>
        {(project.contractors || []).length > 0 ? (
          <div class="space-y-4">
            {project.contractors.map((c: any) => (
              <div class="bg-cream-dark border border-stone-light/20 rounded-lg p-5">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="text-sm text-charcoal font-body font-medium">{c.name}</span>
                  {(c.trades || []).length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {c.trades.map((trade: string) => (
                        <span class="inline-flex px-2 py-0.5 rounded-full text-xs tracking-wide bg-stone-light/15 text-stone font-body">
                          {trade}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
            <p class="text-sm text-stone font-body mt-4">
              Contact Liz for additional contractor details.
            </p>
          </div>
        ) : (
          <p class="text-sm text-stone font-body">
            No contractors have been assigned to this project yet.
          </p>
        )}
      </section>

      {/* Section: Contact Liz */}
      <section class="py-12 border-t border-stone-light/20">
        <h2 class="font-heading text-xl font-light text-charcoal mb-6">
          Contact Liz
        </h2>
        <div class="bg-cream-dark border border-stone-light/20 rounded-lg p-6">
          <p class="text-sm text-stone font-body mb-4">
            For questions about this building project, contact Liz
          </p>
          <div class="space-y-2">
            {siteContact?.contactPhone && (
              <a
                href={"tel:" + siteContact.contactPhone}
                class="block text-sm text-charcoal hover:text-terracotta transition-colors font-body"
              >
                {siteContact.contactPhone}
              </a>
            )}
            {siteContact?.contactEmail && (
              <a
                href={"mailto:" + siteContact.contactEmail}
                class="block text-sm text-charcoal hover:text-terracotta transition-colors font-body"
              >
                {siteContact.contactEmail}
              </a>
            )}
          </div>
        </div>
      </section>

    </div>
  </main>
</PortalLayout>
