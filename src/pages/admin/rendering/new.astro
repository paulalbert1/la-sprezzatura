---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getTenantClient } from "../../../lib/tenantClient";
import WizardContainer from "../../../components/admin/rendering/WizardContainer.tsx";

const tenantId = Astro.locals.tenantId;
if (!tenantId) return Astro.redirect("/admin/login");

// Server-side reads — keep STUDIO_API_SECRET inside frontmatter so it never lands
// in the client bundle via module evaluation (T-33-01 mitigation). The token is
// forwarded to the React island as a string prop.
const sanityUserId = Astro.locals.sanityUserId ?? "";
const studioToken = import.meta.env.STUDIO_API_SECRET ?? "";

const client = getTenantClient(tenantId);
// Pre-fetch projects server-side (Risk 4: StepSetup receives projects as a prop
// instead of calling useClient() like the Studio version did).
const projects = await client.fetch<{ _id: string; title: string }[]>(
  `*[_type == "project"] | order(title asc) { _id, title }`,
);

const prefilledProjectId = Astro.url.searchParams.get("project") ?? "";

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Rendering", href: "/admin/rendering" },
  { label: "New session" },
];
---

<AdminLayout title="New Session - Rendering" pageTitle="Rendering" breadcrumbs={breadcrumbs}>
  <WizardContainer
    client:load
    projects={projects}
    sanityUserId={sanityUserId}
    studioToken={studioToken}
    prefilledProjectId={prefilledProjectId}
  />
</AdminLayout>
