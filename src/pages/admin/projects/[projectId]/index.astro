---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import EditableTitle from "../../../../components/admin/EditableTitle.tsx";
import ProjectTasks from "../../../../components/admin/ProjectTasks.tsx";
import ClientActionItemsList from "../../../../components/admin/ClientActionItemsList.tsx";
import MilestonesList from "../../../../components/admin/MilestonesList.tsx";
import ProcurementEditor from "../../../../components/admin/ProcurementEditor.tsx";
import ContactCardWrapper from "../../../../components/admin/ContactCardWrapper.tsx";
import QuickAssignTypeahead from "../../../../components/admin/QuickAssignTypeahead.tsx";
import SendUpdateButton from "../../../../components/admin/SendUpdateButton.tsx";
import {
  getAdminProjectDetail,
  RENDERING_SESSIONS_BY_PROJECT_QUERY,
} from "../../../../sanity/queries";
import { getTenantClient } from "../../../../lib/tenantClient";
import { STAGE_META } from "../../../../lib/portalStages";
import { format, parseISO } from "date-fns";

const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/admin/projects");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);

const project = await getAdminProjectDetail(client, projectId);
if (!project) {
  return Astro.redirect("/admin/projects");
}

const stageMeta = STAGE_META[project.pipelineStage as keyof typeof STAGE_META];
const stageChangedLabel = project.stageChangedAt
  ? `Since ${format(parseISO(project.stageChangedAt), "MMM d")}`
  : "";

// Phase 33 D-01: server-side prefetch of the rendering session count for this
// project. Used by the Rendering tab badge. Query lives in src/sanity/queries.ts
// and returns _id, sessionTitle, status, createdAt, renderingCount per session.
const renderingSessions = (await client.fetch(
  RENDERING_SESSIONS_BY_PROJECT_QUERY,
  { projectId },
)) as Array<{ _id: string }> | null;
const renderingSessionCount = renderingSessions?.length ?? 0;

// Rendering tab is "active" only if the user is already on
// /admin/rendering?project={projectId} — on this page it is always false,
// but the check keeps the styling honest if the layout is reused.
const isRenderingTabActive =
  Astro.url.pathname.startsWith("/admin/rendering") &&
  Astro.url.searchParams.get("project") === projectId;

// Phase 34 Plan 04 — SendUpdateButton prefetch.
// Compute per-section counts for the Send Update modal on the server so the
// React island doesn't need a second fetch. Pending reviews are fetched via a
// dedicated lightweight query (artifacts aren't in ADMIN_PROJECT_DETAIL_QUERY).
const now = new Date();
const milestonesList = (project.milestones || []) as Array<{
  date?: string;
  completed?: boolean;
}>;
const milestonesTotal = milestonesList.length;
const milestonesUpcoming = milestonesList.filter((m) => {
  if (m.completed) return false;
  if (!m.date) return false;
  return new Date(m.date).getTime() >= now.getTime();
}).length;

const procurementList = (project.procurementItems || []) as Array<{
  status?: string;
}>;
const procurementTotal = procurementList.length;
const procurementDelivered = procurementList.filter(
  (p) => p.status === "delivered" || p.status === "installed",
).length;

const pendingReviewsResult = (await client.fetch(
  `count(*[_type == "project" && _id == $projectId][0].artifacts[
    defined(currentVersionKey) && count(decisionLog[action == "approved"]) == 0
  ])`,
  { projectId },
)) as number | null;
const pendingReviewsCount = pendingReviewsResult ?? 0;

const sendUpdateProjectSummary = {
  _id: project._id,
  title: project.title,
  engagementType: project.engagementType || "",
  clients: (project.projectClients || [])
    .filter((c: { email?: string }) => Boolean(c.email))
    .map((c: { _id: string; name: string; email: string }) => ({
      _id: c._id,
      name: c.name,
      email: c.email,
    })),
  milestones: { total: milestonesTotal, upcoming: milestonesUpcoming },
  procurement: { items: procurementTotal, delivered: procurementDelivered },
  pendingReviews: { count: pendingReviewsCount },
};

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Projects", href: "/admin/projects" },
  { label: project.title },
];
---

<AdminLayout title={project.title + " - Studio"} pageTitle={project.title} breadcrumbs={breadcrumbs}>
  <div class="max-w-5xl">
    {/* Project header -- title with client name below */}
    <div class="flex items-start gap-2 mb-7">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <EditableTitle client:load title={project.title} projectId={projectId} />
          {stageMeta && (
            <span
              class="inline-flex px-[11px] py-[3px] rounded-full text-[10.5px] font-medium uppercase"
              style="background-color: #F5EDD8; color: #9A7B4B; border: 0.5px solid #E8D5A8; letter-spacing: 0.06em; margin-top: -3px;"
            >
              {stageMeta.title}
            </span>
          )}
          {stageChangedLabel && (
            <span class="text-[11.5px] ml-1" style="color: #9E8E80; margin-top: -3px;">{stageChangedLabel}</span>
          )}
        </div>
        {project.projectClients && project.projectClients[0] && (
          <div class="flex items-center gap-2 mt-1">
            <a
              href={`/admin/clients/${project.projectClients[0]._id}`}
              style="font-family: var(--font-sans); font-size: 13px; color: #6B5E52; text-decoration: none;"
              onmouseover="this.style.color='#9A7B4B'"
              onmouseout="this.style.color='#6B5E52'"
            >
              {project.projectClients[0].name}
            </a>
            {project.projectClients[0].email && (
              <span style="font-family: var(--font-sans); font-size: 12.5px; color: #9E8E80;">
                · {project.projectClients[0].email}
              </span>
            )}
          </div>
        )}
      </div>
      <div class="ml-auto flex items-center gap-2">
        <a
          href={`/admin/rendering?project=${projectId}`}
          class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${
            isRenderingTabActive
              ? "bg-[#F5EDD8] text-[#9A7B4B]"
              : "text-[#6B5E52] hover:bg-[#F3EDE3]"
          }`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="w-4 h-4"
            data-icon="SparklesIcon"
          >
            <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
            <path d="M20 2v4" />
            <path d="M22 4h-4" />
            <circle cx="4" cy="20" r="2" />
          </svg>
          Rendering
          {renderingSessionCount > 0 && (
            <span
              class="inline-flex items-center rounded-full px-1.5"
              style="background:#F5EDD8; color:#9A7B4B; font-size:11.5px; font-weight:600; height:18px;"
            >
              {renderingSessionCount}
            </span>
          )}
        </a>
        <SendUpdateButton client:load project={sendUpdateProjectSummary} />
      </div>
    </div>

    {/* Two-column grid: left = Tasks + Client Action Items stacked; right = Milestones + Contractors stacked */}
    <div
      class="mb-[14px]"
      style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start;"
    >
      {/* Left column: Tasks (top) + Client Action Items (bottom) */}
      <div style="display: flex; flex-direction: column; gap: 14px;">
        <ProjectTasks
          client:load
          tasks={project.tasks || []}
          projectId={projectId}
        />
        <ClientActionItemsList
          client:load
          items={project.clientActionItems || []}
          projectId={projectId}
        />
      </div>

      {/* Right column: Milestones (top) + Contractors (bottom) */}
      <div style="display: flex; flex-direction: column; gap: 14px;">
      <div id="milestones">
        <MilestonesList
          client:load
          milestones={project.milestones || []}
          projectId={projectId}
          scheduleUrl={`/admin/projects/${projectId}/schedule`}
        />
      </div>

      {/* Contractors */}
      <div
        style="background-color: #FFFEFB; border: 0.5px solid #E8DDD0; border-radius: 10px; padding: 18px 20px;"
      >
        <h2
          class="mb-[14px]"
          style="font-family: var(--font-sans); font-size: 10.5px; font-weight: 500; color: #9E8E80; letter-spacing: 0.1em; text-transform: uppercase;"
        >
          Contractors
        </h2>
        <hr style="border: none; border-top: 0.5px solid #E8DDD0; margin: 0 0 14px 0;" />
        <div class="flex flex-wrap gap-[7px] items-center">
          {project.projectContractors && project.projectContractors.map((pc: any) => pc.contractor && (
            <ContactCardWrapper
              client:load
              entityId={pc.contractor._id}
              entityType="contractor"
              name={pc.contractor.name}
              href={`/admin/contractors/${pc.contractor._id}`}
              contactData={{
                _id: pc.contractor._id,
                name: pc.contractor.name,
                email: pc.contractor.email || "",
                phone: pc.contractor.phone || "",
                entityType: "contractor" as const,
              }}
              className="inline-flex cursor-pointer"
            >
              <span
                class="inline-flex items-center gap-[7px] pl-[7px] pr-[11px] py-[5px] rounded-full text-[12.5px]"
                style="background-color: #FAF7F2; color: #2C2520; border: 0.5px solid #D4C8B8;"
              >
                <span
                  class="w-5 h-5 rounded-full flex items-center justify-center text-[8.5px] font-medium"
                  style="background-color: #F3EDE3; color: #9A7B4B; border: 0.5px solid #D4C8B8;"
                >
                  {pc.contractor.name.split(" ").map((n: string) => n[0]).join("").slice(0, 2).toUpperCase()}
                </span>
                {pc.contractor.name}
                {pc.trade && <span style="color: #9E8E80; font-size: 11px;">({pc.trade})</span>}
              </span>
            </ContactCardWrapper>
          ))}

          <button
            type="button"
            onclick="document.getElementById('quick-assign-input')?.focus();"
            class="inline-flex items-center gap-[6px] px-[11px] py-[5px] rounded-full transition-colors hover:text-[#9A7B4B] hover:border-[#9A7B4B]"
            style="border: 0.5px dashed #D4C8B8; font-size: 12px; color: #9E8E80; background-color: transparent; letter-spacing: 0.02em; font-family: var(--font-sans);"
          >
            + Add contractor
          </button>
        </div>

        <div class="mt-3">
          <QuickAssignTypeahead
            client:load
            projectId={projectId}
            existingClients={project.projectClients || []}
            existingContractors={(project.projectContractors || []).map((pc: any) => ({
              _id: pc.contractor?._id || "",
              name: pc.contractor?.name || "",
              trade: pc.trade,
            }))}
          />
        </div>
      </div>
      </div>
    </div>

    {/* Procurement section - full width */}
    {project.engagementType === "full-interior-design" && (
      <div id="procurement" class="mb-8">
        <ProcurementEditor
          client:load
          items={project.procurementItems || []}
          projectId={projectId}
        />
      </div>
    )}
  </div>
</AdminLayout>
