---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import ProjectTasks from "../../../../components/admin/ProjectTasks.tsx";
import ContactCardWrapper from "../../../../components/admin/ContactCardWrapper.tsx";
import QuickAssignTypeahead from "../../../../components/admin/QuickAssignTypeahead.tsx";
import { getAdminProjectDetail } from "../../../../sanity/queries";
import { getTenantClient } from "../../../../lib/tenantClient";
import { STAGE_META } from "../../../../lib/portalStages";
import { getDaysInStage } from "../../../../lib/dashboardUtils";

const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/admin/projects");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);

const project = await getAdminProjectDetail(client, projectId);
if (!project) {
  return Astro.redirect("/admin/projects");
}

const stageMeta = STAGE_META[project.pipelineStage as keyof typeof STAGE_META];
const daysInStage = getDaysInStage(project.stageChangedAt);

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Projects", href: "/admin/projects" },
  { label: project.title },
];
---

<AdminLayout title={project.title + " - Studio"} pageTitle={project.title} breadcrumbs={breadcrumbs}>
  <div class="max-w-4xl">
    {/* Project header with stage badge and days-in-stage */}
    <div class="flex items-center gap-4 mb-8">
      <h1 class="text-xl font-semibold font-body text-charcoal">{project.title}</h1>
      {stageMeta && (
        <span class="inline-flex px-2.5 py-1 rounded-md text-xs font-medium bg-terracotta/10 text-terracotta">
          {stageMeta.title}
        </span>
      )}
      <span class="text-[11px] text-stone-light font-body">{daysInStage}d in stage</span>
    </div>

    {/* Placeholder sections for future phases (milestones, procurement) */}
    <div id="milestones" class="mb-8">
      {/* Milestones section placeholder -- expanded in future phases */}
    </div>

    <div id="procurement" class="mb-8">
      {/* Procurement section placeholder -- expanded in future phases */}
    </div>

    {/* Team section */}
    <div class="mb-8">
      <h2 class="text-sm font-semibold font-body text-charcoal mb-4">Team</h2>
      <div class="bg-white rounded-xl border border-stone-light/40 p-5">
        {/* Clients sub-section */}
        {project.projectClients && project.projectClients.length > 0 && (
          <div class="mb-4">
            <h3 class="text-[11px] font-semibold text-stone uppercase tracking-wider mb-2">Clients</h3>
            <div class="flex flex-wrap gap-3">
              {project.projectClients.map((c: any) => (
                <ContactCardWrapper
                  client:load
                  entityId={c._id}
                  entityType="client"
                  name={c.name}
                  href={`/admin/clients/${c._id}`}
                  contactData={{
                    _id: c._id,
                    name: c.name,
                    email: c.email || "",
                    phone: c.phone || "",
                    preferredContact: c.preferredContact || "",
                    entityType: "client" as const,
                  }}
                  className="text-sm font-body text-terracotta hover:underline cursor-pointer"
                >
                  {c.name}
                </ContactCardWrapper>
              ))}
            </div>
          </div>
        )}

        {/* Contractors sub-section */}
        {project.projectContractors && project.projectContractors.length > 0 && (
          <div class="mb-4">
            <h3 class="text-[11px] font-semibold text-stone uppercase tracking-wider mb-2">Contractors</h3>
            <div class="flex flex-wrap gap-3">
              {project.projectContractors.map((pc: any) => pc.contractor && (
                <div class="flex items-center gap-1.5">
                  <ContactCardWrapper
                    client:load
                    entityId={pc.contractor._id}
                    entityType="contractor"
                    name={pc.contractor.name}
                    href={`/admin/contractors/${pc.contractor._id}`}
                    contactData={{
                      _id: pc.contractor._id,
                      name: pc.contractor.name,
                      email: pc.contractor.email || "",
                      phone: pc.contractor.phone || "",
                      entityType: "contractor" as const,
                    }}
                    className="text-sm font-body text-terracotta hover:underline cursor-pointer"
                  >
                    {pc.contractor.name}
                  </ContactCardWrapper>
                  {pc.trade && (
                    <span class="text-[11px] text-stone-light font-body">({pc.trade})</span>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Quick-assign typeahead */}
        <QuickAssignTypeahead
          client:load
          projectId={projectId}
          existingClients={project.projectClients || []}
          existingContractors={(project.projectContractors || []).map((pc: any) => ({
            _id: pc.contractor?._id || "",
            name: pc.contractor?.name || "",
            trade: pc.trade,
          }))}
        />
      </div>
    </div>

    {/* Tasks section - React island */}
    <ProjectTasks
      client:load
      tasks={project.tasks || []}
      projectId={projectId}
    />
  </div>
</AdminLayout>
