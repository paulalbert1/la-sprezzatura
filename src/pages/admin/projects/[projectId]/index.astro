---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import ProjectTasks from "../../../../components/admin/ProjectTasks.tsx";
import ProcurementEditor from "../../../../components/admin/ProcurementEditor.tsx";
import ContactCardWrapper from "../../../../components/admin/ContactCardWrapper.tsx";
import QuickAssignTypeahead from "../../../../components/admin/QuickAssignTypeahead.tsx";
import { getAdminProjectDetail } from "../../../../sanity/queries";
import { getTenantClient } from "../../../../lib/tenantClient";
import { STAGE_META } from "../../../../lib/portalStages";
import { getDaysInStage, isMilestoneOverdue } from "../../../../lib/dashboardUtils";
import { format, parseISO } from "date-fns";

const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/admin/projects");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);

const project = await getAdminProjectDetail(client, projectId);
if (!project) {
  return Astro.redirect("/admin/projects");
}

const stageMeta = STAGE_META[project.pipelineStage as keyof typeof STAGE_META];
const daysInStage = getDaysInStage(project.stageChangedAt);

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Projects", href: "/admin/projects" },
  { label: project.title },
];
---

<AdminLayout title={project.title + " - Studio"} pageTitle={project.title} breadcrumbs={breadcrumbs}>
  <div class="max-w-4xl">
    {/* Project header with stage badge and days-in-stage */}
    <div class="flex items-center gap-4 mb-8">
      <h1 class="text-xl font-semibold font-body text-charcoal">{project.title}</h1>
      {stageMeta && (
        <span class="inline-flex px-2.5 py-1 rounded-md text-xs font-medium bg-terracotta/10 text-terracotta">
          {stageMeta.title}
        </span>
      )}
      <span class="text-[11px] text-stone-light font-body">{daysInStage}d in stage</span>
    </div>

    {/* Milestones & Schedule */}
    <div id="milestones" class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold font-body text-charcoal">Milestones</h2>
        <a href={`/admin/projects/${projectId}/schedule`} class="text-xs text-terracotta hover:text-terracotta/80 font-body transition-colors">
          View Schedule →
        </a>
      </div>
      {project.milestones && project.milestones.length > 0 ? (
        <div class="bg-white rounded-xl border border-stone-light/40 overflow-hidden">
          {project.milestones.map((m: any) => {
            const overdue = isMilestoneOverdue(m);
            return (
              <div class="flex items-center gap-3 px-5 py-3 border-b border-stone-light/10 last:border-b-0">
                <span class={`w-2 h-2 rounded-full shrink-0 ${m.completed ? "bg-emerald-500" : overdue ? "bg-red-400" : "bg-stone-light/40"}`} />
                <span class={`text-sm font-body flex-1 ${m.completed ? "text-stone line-through" : overdue ? "text-red-600" : "text-charcoal"}`}>
                  {m.name}
                </span>
                {m.date && (
                  <span class={`text-xs font-body shrink-0 ${overdue && !m.completed ? "text-red-500 font-medium" : "text-stone-light"}`}>
                    {format(parseISO(m.date), "MMM d")}
                  </span>
                )}
              </div>
            );
          })}
        </div>
      ) : (
        <div class="bg-white rounded-xl border border-stone-light/40 px-5 py-6 text-center">
          <p class="text-sm text-stone font-body">No milestones yet</p>
          <a href={`/admin/projects/${projectId}/schedule`} class="text-xs text-terracotta hover:text-terracotta/80 font-body mt-1 inline-block">
            Add milestones in Schedule →
          </a>
        </div>
      )}
    </div>

    {project.engagementType === "full-interior-design" && (
      <div id="procurement" class="mb-8">
        <h2 class="text-sm font-semibold font-body text-charcoal mb-4">Procurement</h2>
        <ProcurementEditor
          client:load
          items={project.procurementItems || []}
          projectId={projectId}
        />
      </div>
    )}

    {/* Team section */}
    <div class="mb-8">
      <h2 class="text-sm font-semibold font-body text-charcoal mb-4">Team</h2>
      <div class="bg-white rounded-xl border border-stone-light/40 p-5">
        {/* Clients sub-section */}
        {project.projectClients && project.projectClients.length > 0 && (
          <div class="mb-4">
            <h3 class="text-[11px] font-semibold text-stone uppercase tracking-wider mb-2">Clients</h3>
            <div class="flex flex-wrap gap-3">
              {project.projectClients.map((c: any) => (
                <ContactCardWrapper
                  client:load
                  entityId={c._id}
                  entityType="client"
                  name={c.name}
                  href={`/admin/clients/${c._id}`}
                  contactData={{
                    _id: c._id,
                    name: c.name,
                    email: c.email || "",
                    phone: c.phone || "",
                    preferredContact: c.preferredContact || "",
                    entityType: "client" as const,
                  }}
                  className="text-sm font-body text-terracotta hover:underline cursor-pointer"
                >
                  {c.name}
                </ContactCardWrapper>
              ))}
            </div>
          </div>
        )}

        {/* Contractors sub-section */}
        {project.projectContractors && project.projectContractors.length > 0 && (
          <div class="mb-4">
            <h3 class="text-[11px] font-semibold text-stone uppercase tracking-wider mb-2">Contractors</h3>
            <div class="flex flex-wrap gap-3">
              {project.projectContractors.map((pc: any) => pc.contractor && (
                <div class="flex items-center gap-1.5">
                  <ContactCardWrapper
                    client:load
                    entityId={pc.contractor._id}
                    entityType="contractor"
                    name={pc.contractor.name}
                    href={`/admin/contractors/${pc.contractor._id}`}
                    contactData={{
                      _id: pc.contractor._id,
                      name: pc.contractor.name,
                      email: pc.contractor.email || "",
                      phone: pc.contractor.phone || "",
                      entityType: "contractor" as const,
                    }}
                    className="text-sm font-body text-terracotta hover:underline cursor-pointer"
                  >
                    {pc.contractor.name}
                  </ContactCardWrapper>
                  {pc.trade && (
                    <span class="text-[11px] text-stone-light font-body">({pc.trade})</span>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Quick-assign typeahead */}
        <QuickAssignTypeahead
          client:load
          projectId={projectId}
          existingClients={project.projectClients || []}
          existingContractors={(project.projectContractors || []).map((pc: any) => ({
            _id: pc.contractor?._id || "",
            name: pc.contractor?.name || "",
            trade: pc.trade,
          }))}
        />
      </div>
    </div>

    {/* Tasks section - React island */}
    <ProjectTasks
      client:load
      tasks={project.tasks || []}
      projectId={projectId}
    />
  </div>
</AdminLayout>
