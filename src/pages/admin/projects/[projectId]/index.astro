---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import EditableTitle from "../../../../components/admin/EditableTitle.tsx";
import ProjectTasks from "../../../../components/admin/ProjectTasks.tsx";
import MilestonesList from "../../../../components/admin/MilestonesList.tsx";
import ProcurementEditor from "../../../../components/admin/ProcurementEditor.tsx";
import ContactCardWrapper from "../../../../components/admin/ContactCardWrapper.tsx";
import QuickAssignTypeahead from "../../../../components/admin/QuickAssignTypeahead.tsx";
import { getAdminProjectDetail } from "../../../../sanity/queries";
import { getTenantClient } from "../../../../lib/tenantClient";
import { STAGE_META } from "../../../../lib/portalStages";
import { getDaysInStage } from "../../../../lib/dashboardUtils";

const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/admin/projects");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);

const project = await getAdminProjectDetail(client, projectId);
if (!project) {
  return Astro.redirect("/admin/projects");
}

const stageMeta = STAGE_META[project.pipelineStage as keyof typeof STAGE_META];
const daysInStage = getDaysInStage(project.stageChangedAt);

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Projects", href: "/admin/projects" },
  { label: project.title },
];
---

<AdminLayout title={project.title + " - Studio"} pageTitle={project.title} breadcrumbs={breadcrumbs}>
  <div class="max-w-5xl">
    {/* Project header -- no border, let title breathe */}
    <div class="flex items-center gap-2 mb-7">
      <EditableTitle client:load title={project.title} projectId={projectId} />
      {stageMeta && (
        <span
          class="inline-flex px-[11px] py-[3px] rounded-full text-[10.5px] font-medium uppercase"
          style="background-color: #F5EDD8; color: #9A7B4B; border: 0.5px solid #E8D5A8; letter-spacing: 0.06em; margin-top: -4px;"
        >
          {stageMeta.title}
        </span>
      )}
      <span class="text-[11.5px] ml-1" style="color: #9E8E80; margin-top: -4px;">{daysInStage}d in stage</span>
    </div>

    {/* Two-column layout: Tasks (left) + Milestones (right) */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[14px] mb-[14px]">
      <div>
        <ProjectTasks
          client:load
          tasks={project.tasks || []}
          projectId={projectId}
        />
      </div>

      <div id="milestones">
        <MilestonesList
          client:load
          milestones={project.milestones || []}
          projectId={projectId}
          scheduleUrl={`/admin/projects/${projectId}/schedule`}
        />
      </div>
    </div>

    {/* Contractors section - full width (no "Team" label, Contractors at h2 weight) */}
    <div
      class="mb-[14px] rounded-[10px]"
      style="background-color: #FFFEFB; border: 0.5px solid #E8DDD0; padding: 18px 20px;"
    >
      <h2
        class="mb-[14px]"
        style="font-family: var(--font-sans); font-size: 10.5px; font-weight: 500; color: #9E8E80; letter-spacing: 0.1em; text-transform: uppercase;"
      >
        Contractors
      </h2>

      {/* Clients chips */}
      {project.projectClients && project.projectClients.length > 0 && (
        <div class="mb-3">
          <div
            class="mb-[10px]"
            style="font-family: var(--font-sans); font-size: 10.5px; font-weight: 500; color: #9E8E80; letter-spacing: 0.08em; text-transform: uppercase;"
          >
            Clients
          </div>
          <div class="flex flex-wrap gap-[7px]">
            {project.projectClients.map((c: any) => (
              <ContactCardWrapper
                client:load
                entityId={c._id}
                entityType="client"
                name={c.name}
                href={`/admin/clients/${c._id}`}
                contactData={{
                  _id: c._id,
                  name: c.name,
                  email: c.email || "",
                  phone: c.phone || "",
                  preferredContact: c.preferredContact || "",
                  entityType: "client" as const,
                }}
                className="inline-flex items-center gap-[7px] px-[11px] py-[5px] rounded-full text-[12.5px] cursor-pointer"
              >
                <span style="background-color: #FAF7F2; color: #2C2520; border: 0.5px solid #D4C8B8; padding: 5px 11px; border-radius: 20px;">{c.name}</span>
              </ContactCardWrapper>
            ))}
          </div>
        </div>
      )}

      {/* Contractors chips */}
      {project.projectContractors && project.projectContractors.length > 0 && (
        <div class="flex flex-wrap gap-[7px]">
          {project.projectContractors.map((pc: any) => pc.contractor && (
            <ContactCardWrapper
              client:load
              entityId={pc.contractor._id}
              entityType="contractor"
              name={pc.contractor.name}
              href={`/admin/contractors/${pc.contractor._id}`}
              contactData={{
                _id: pc.contractor._id,
                name: pc.contractor.name,
                email: pc.contractor.email || "",
                phone: pc.contractor.phone || "",
                entityType: "contractor" as const,
              }}
              className="inline-flex cursor-pointer"
            >
              <span
                class="inline-flex items-center gap-[7px] pl-[7px] pr-[11px] py-[5px] rounded-full text-[12.5px]"
                style="background-color: #FAF7F2; color: #2C2520; border: 0.5px solid #D4C8B8;"
              >
                <span
                  class="w-5 h-5 rounded-full flex items-center justify-center text-[8.5px] font-medium"
                  style="background-color: #F3EDE3; color: #9A7B4B; border: 0.5px solid #D4C8B8;"
                >
                  {pc.contractor.name.split(" ").map((n: string) => n[0]).join("").slice(0, 2).toUpperCase()}
                </span>
                {pc.contractor.name}
                {pc.trade && <span style="color: #9E8E80; font-size: 11px;">({pc.trade})</span>}
              </span>
            </ContactCardWrapper>
          ))}
        </div>
      )}

      <div class="mt-3">
        <QuickAssignTypeahead
          client:load
          projectId={projectId}
          existingClients={project.projectClients || []}
          existingContractors={(project.projectContractors || []).map((pc: any) => ({
            _id: pc.contractor?._id || "",
            name: pc.contractor?.name || "",
            trade: pc.trade,
          }))}
        />
      </div>
    </div>

    {/* Procurement section - full width */}
    {project.engagementType === "full-interior-design" && (
      <div id="procurement" class="mb-8">
        <ProcurementEditor
          client:load
          items={project.procurementItems || []}
          projectId={projectId}
        />
      </div>
    )}
  </div>
</AdminLayout>
