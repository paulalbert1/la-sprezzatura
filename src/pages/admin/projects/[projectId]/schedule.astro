---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import ScheduleEditor from "../../../../components/admin/ScheduleEditor.tsx";
import { getAdminScheduleData, getAllContractors } from "../../../../sanity/queries";

const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/admin/projects");
}

const data = await getAdminScheduleData(projectId);
if (!data) {
  return Astro.redirect("/admin/projects");
}

const allContractors = await getAllContractors();

const breadcrumbs = [
  { label: "Projects", href: "/admin/projects" },
  { label: data.title, href: `/admin/projects/${projectId}` },
  { label: "Schedule" },
];
---

<AdminLayout title={data.title + " — Schedule"} pageTitle="Schedule" breadcrumbs={breadcrumbs}>
  <ScheduleEditor
    client:load
    scheduleData={data}
    projectId={projectId}
    allContractors={allContractors}
  />
</AdminLayout>
