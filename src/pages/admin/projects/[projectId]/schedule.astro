---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { getTenantClient } from "../../../../lib/tenantClient";

const projectId = Astro.params.projectId;
if (!projectId) {
  return Astro.redirect("/admin/projects");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);

const project = await client.fetch<{ _id: string; title: string } | null>(
  `*[_type == "project" && _id == $projectId][0] { _id, title }`,
  { projectId },
);
if (!project) {
  return Astro.redirect("/admin/projects");
}

const breadcrumbs = [
  { label: "Projects", href: "/admin/projects" },
  { label: project.title, href: `/admin/projects/${projectId}` },
  { label: "Schedule" },
];
---

<AdminLayout title={project.title + " — Schedule"} pageTitle="Schedule" breadcrumbs={breadcrumbs}>
  <p style="padding: 2rem; color: #6b7280; font-style: italic;">
    Schedule UI under construction (Phase 44 in progress).
  </p>
</AdminLayout>
