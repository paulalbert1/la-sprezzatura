---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import WorkflowTracker from "../../../../components/admin/workflow/WorkflowTracker.tsx";
import BlankWorkflowState from "../../../../components/admin/workflow/BlankWorkflowState.tsx";
import { getTenantClient } from "../../../../lib/tenantClient";
import {
  detectDormancy, computeWarnings, computeMetrics,
  getAdminTransitions, isBlocked, isApprovalOverdue,
  getNextActionableMilestone,
  type AdminTransition,
} from "../../../../lib/workflow/engine";
import { PROJECT_WORKFLOW_QUERY } from "../../../../sanity/queries";
import type { ProjectWorkflow } from "../../../../lib/workflow/types";

const projectId = Astro.params.projectId;
if (!projectId) return Astro.redirect("/admin/projects");

const tenantId = Astro.locals.tenantId;
if (!tenantId) return Astro.redirect("/admin/login");
const client = getTenantClient(tenantId);

const project = await client.fetch(
  `*[_type == "project" && _id == $projectId][0]{
    _id, title,
    "clientFirstName": client->firstName,
    "clientLastName": client->lastName
  }`,
  { projectId },
);
if (!project) return Astro.redirect("/admin/projects");

const workflowRaw = await client.fetch(PROJECT_WORKFLOW_QUERY, { projectId }) as ProjectWorkflow | null;
const templates = await client.fetch(
  `*[_type == "workflowTemplate"] | order(name asc) { _id, name }`,
) as Array<{ _id: string; name: string }>;

let workflow = workflowRaw;
let templateName = "";

if (workflow) {
  // Fetch template name for header sub-line (best-effort; tolerate deletion)
  const tmpl = await client.fetch(
    `*[_type == "workflowTemplate" && _id == $id][0]{ name }`,
    { id: workflow.templateId },
  ) as { name?: string } | null;
  templateName = tmpl?.name ?? "(deleted template)";

  // Lazy dormancy evaluation (D-15)
  if (workflow.status === "active") {
    const dormancy = detectDormancy(workflow);
    if (dormancy.dormant) {
      await client.patch(workflow._id).set({ status: "dormant" }).commit();
      workflow = { ...workflow, status: "dormant" };
    }
  }
}

const warnings = workflow ? computeWarnings(workflow) : [];
const metrics = workflow
  ? computeMetrics(workflow)
  : { complete: 0, inProgress: 0, awaitingClient: 0, blocked: 0, progressPct: 0 };
const nextActionable = workflow ? getNextActionableMilestone(workflow) : null;

// Precompute engine outputs keyed by phaseId:milestoneId(:instanceKey)
const transitionsById: Record<string, Array<AdminTransition>> = {};
const blockedById: Record<string, { blocked: boolean; reason?: string }> = {};
const gateSubMessageById: Record<string, string> = {};
const overdueReasonById: Record<string, string> = {};

if (workflow) {
  const now = new Date();
  for (const phase of workflow.phases) {
    for (const m of phase.milestones) {
      const key = `${phase.id}:${m.id}`;
      blockedById[key] = isBlocked(workflow, phase.id, m.id);
      transitionsById[key] = getAdminTransitions(workflow, phase.id, m.id, undefined, now);
      // Gate sub-message: only when awaiting_* OR blocked with gate
      if ((m.status === "awaiting_client" || m.status === "awaiting_payment") && m.gate) {
        const overdue = isApprovalOverdue(workflow, phase.id, m.id, now);
        const waitingSuffix =
          overdue.businessDaysWaiting > 0
            ? ` · ${overdue.businessDaysWaiting} biz days waiting`
            : "";
        gateSubMessageById[key] = `Awaiting ${m.gate}${waitingSuffix}`;
        if (overdue.overdue) {
          overdueReasonById[key] = `Awaiting client — overdue by ${overdue.businessDaysWaiting} biz days`;
        }
      }
      // Sub-row transitions
      if (m.instances) {
        for (const inst of m.instances) {
          const subKey = `${phase.id}:${m.id}:${inst._key}`;
          transitionsById[subKey] = getAdminTransitions(workflow, phase.id, m.id, inst._key, now);
        }
      }
    }
  }
}

const clientInitials = ((project.clientFirstName?.[0] ?? "") + (project.clientLastName?.[0] ?? "")).toUpperCase()
  || (project.title as string).slice(0, 2).toUpperCase();

const breadcrumbs = [
  { label: "Projects", href: "/admin/projects" },
  { label: project.title as string, href: `/admin/projects/${projectId}` },
  { label: "Schedule" },
];
---

<AdminLayout
  title={`${project.title} — Schedule`}
  pageTitle="Schedule"
  breadcrumbs={breadcrumbs}
>
  {workflow ? (
    <WorkflowTracker
      client:load
      projectId={projectId}
      projectTitle={project.title}
      clientInitials={clientInitials}
      workflow={workflow}
      templateName={templateName}
      warnings={warnings}
      metrics={metrics}
      templates={templates}
      transitionsById={transitionsById}
      blockedById={blockedById}
      gateSubMessageById={gateSubMessageById}
      overdueReasonById={overdueReasonById}
      nextActionable={nextActionable}
    />
  ) : (
    <BlankWorkflowState client:load projectId={projectId} templates={templates} />
  )}
</AdminLayout>
