---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import EntityDetailForm from "../../../../components/admin/EntityDetailForm.tsx";
import LinkedProjects from "../../../../components/admin/LinkedProjects.tsx";
import { getTenantClient } from "../../../../lib/tenantClient";
import { getAdminContractorDetail, SITE_SETTINGS_QUERY } from "../../../../sanity/queries";
import { relationshipLabel } from "../../../../lib/relationshipLabel";
import { formatTrade } from "../../../../lib/trades";

const contractorId = Astro.params.contractorId;
if (!contractorId) {
  return Astro.redirect("/admin/trades");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const sanityClient = getTenantClient(tenantId);

const isNew = contractorId === "new";
let contractorData = null;
let projects: any[] = [];

const siteSettingsRaw = await sanityClient.fetch(SITE_SETTINGS_QUERY);
const tradeCatalog: string[] = (siteSettingsRaw as any)?.trades ?? [];

if (!isNew) {
  const result = await getAdminContractorDetail(sanityClient, contractorId);
  if (!result?.contractor) {
    return Astro.redirect("/admin/trades");
  }
  contractorData = result.contractor;
  projects = result.projects || [];
}

// Phase 43 TRAD-06 — relationship-scoped document checklist labels.
// For new records (no relationship yet) the detail form is in create mode and
// TradeChecklist is not rendered, so an empty array is safe.
const relationship = !isNew ? (contractorData as any)?.relationship ?? null : null;
const checklistItems: string[] = relationship === "vendor"
  ? (siteSettingsRaw as any)?.vendorChecklistItems ?? []
  : (siteSettingsRaw as any)?.contractorChecklistItems ?? [];

const pageTitle = isNew ? "New Trade" : (contractorData?.name || "Trade");

const relLabel = !isNew && contractorData ? relationshipLabel((contractorData as any).relationship) : null;
const browserTitle = isNew
  ? "New Trade — La Sprezzatura Admin"
  : `${pageTitle} — ${relLabel ?? "Trade"} — La Sprezzatura Admin`;

// Phase 42 TRAD-05 — meta line: {primary trade} · {Contractor|Vendor} · {City, ST}
// Segments are filtered so missing values leave no empty slots and no
// leading/trailing separators. New records render no meta line.
const metaSegments: string[] = [];
if (!isNew && contractorData) {
  const primaryTrade = (contractorData as any).trades?.[0];
  if (primaryTrade) metaSegments.push(formatTrade(primaryTrade));
  metaSegments.push(relationshipLabel((contractorData as any).relationship));
  const cityState = [
    (contractorData as any).address?.city,
    (contractorData as any).address?.state,
  ]
    .filter(Boolean)
    .join(", ");
  if (cityState) metaSegments.push(cityState);
}
const metaLine = metaSegments.join(" · ");

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Trades", href: "/admin/trades" },
  { label: pageTitle },
];
---

<AdminLayout title={browserTitle} pageTitle={pageTitle} breadcrumbs={breadcrumbs}>
  <div class="max-w-4xl">
    {!isNew && metaLine && (
      <p
        class="font-body font-normal mt-1 mb-5"
        style="font-size: 12.5px; line-height: 1.4; letter-spacing: 0.02em; color: var(--color-text-mid);"
      >
        {metaLine}
      </p>
    )}
    <EntityDetailForm
      client:load
      entityType="contractor"
      entity={contractorData}
      isNew={isNew}
      tradeCatalog={tradeCatalog}
      checklistItems={checklistItems}
    />
    {!isNew && (
      <LinkedProjects client:load projects={projects} />
    )}
  </div>
</AdminLayout>
