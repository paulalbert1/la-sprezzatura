---
export const prerender = false;

import AdminLayout from "../../../../layouts/AdminLayout.astro";
import EntityDetailForm from "../../../../components/admin/EntityDetailForm.tsx";
import LinkedProjects from "../../../../components/admin/LinkedProjects.tsx";
import { getTenantClient } from "../../../../lib/tenantClient";
import { getAdminContractorDetail, SITE_SETTINGS_QUERY } from "../../../../sanity/queries";
import { relationshipLabel } from "../../../../lib/relationshipLabel";

const contractorId = Astro.params.contractorId;
if (!contractorId) {
  return Astro.redirect("/admin/trades");
}

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const sanityClient = getTenantClient(tenantId);

const isNew = contractorId === "new";
let contractorData = null;
let projects: any[] = [];

const siteSettingsRaw = await sanityClient.fetch(SITE_SETTINGS_QUERY);
const tradeCatalog: string[] = (siteSettingsRaw as any)?.trades ?? [];

if (!isNew) {
  const result = await getAdminContractorDetail(sanityClient, contractorId);
  if (!result?.contractor) {
    return Astro.redirect("/admin/trades");
  }
  contractorData = result.contractor;
  projects = result.projects || [];
}

const pageTitle = isNew ? "New Trade" : (contractorData?.name || "Trade");

const relLabel = !isNew && contractorData ? relationshipLabel((contractorData as any).relationship) : null;
const browserTitle = isNew
  ? "New Trade — La Sprezzatura Admin"
  : `${pageTitle} — ${relLabel ?? "Trade"} — La Sprezzatura Admin`;

const breadcrumbs = [
  { label: "Dashboard", href: "/admin/dashboard" },
  { label: "Trades", href: "/admin/trades" },
  { label: pageTitle },
];
---

<AdminLayout title={browserTitle} pageTitle={pageTitle} breadcrumbs={breadcrumbs}>
  <div class="max-w-4xl">
    <EntityDetailForm
      client:load
      entityType="contractor"
      entity={contractorData}
      isNew={isNew}
      tradeCatalog={tradeCatalog}
    />
    {!isNew && (
      <LinkedProjects client:load projects={projects} />
    )}
  </div>
</AdminLayout>
