---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import DashboardTasksCard from "../../components/admin/DashboardTasksCard.tsx";
import UpcomingDeliveriesCard from "../../components/admin/UpcomingDeliveriesCard.tsx";
import ActiveProjectsCard from "../../components/admin/ActiveProjectsCard.tsx";
import ContactCardWrapper from "../../components/admin/ContactCardWrapper.tsx";
import { getTenantClient } from "../../lib/tenantClient";
import { getAdminDashboardData } from "../../sanity/queries";
import {
  getOverdueBannerData,
  isMilestoneOverdue,
} from "../../lib/dashboardUtils";
import { format, parseISO } from "date-fns";

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);
const data = await getAdminDashboardData(client);

// Compute overdue banner data (now includes items for specific copy)
const overdueBanner = getOverdueBannerData(data.milestones, data.tasks);

// Split milestones into overdue and upcoming
const overdueMilestones = data.milestones.filter(isMilestoneOverdue);
const upcomingMilestones = data.milestones
  .filter((m) => !isMilestoneOverdue(m) && !m.completed)
  .sort((a, b) => (a.date || "").localeCompare(b.date || ""))
  .slice(0, 4);

// Active projects + deliveries are now rendered by React islands
// (ActiveProjectsCard — Plan 03; UpcomingDeliveriesCard — Plan 02) which own
// their own slicing, filtering, and per-stage color maps.

// Date helpers (delivery status + ETA date formatter moved into
// UpcomingDeliveriesCard as of Phase 35 Plan 02).
function formatMilestoneDate(dateStr: string | null): string {
  if (!dateStr) return "";
  try {
    return format(parseISO(dateStr), "MMM d");
  } catch {
    return dateStr;
  }
}

const today = format(new Date(), "EEEE, MMMM d, yyyy");
---

<AdminLayout title="Dashboard - Studio" pageTitle="Dashboard" breadcrumbs={[{ label: "Dashboard" }]}>
  <div>
    {/* Header with date */}
    <div class="flex justify-between items-baseline mb-4" style="margin-top: -15px;">
      <div></div>
      <span class="text-xs text-stone-light font-body">{today}</span>
    </div>

    {/* Overdue Alert Banner - specific single-item copy only */}
    {overdueBanner.total === 1 && overdueBanner.firstMilestone && (
      <div
        class="bg-red-50 border border-red-200/30 rounded-xl px-4 py-3 mb-6 text-sm text-red-900"
        role="alert"
      >
        <span class="font-semibold">{overdueBanner.firstMilestone.name}</span>
        {" "}is {overdueBanner.firstMilestone.daysOverdue} {overdueBanner.firstMilestone.daysOverdue === 1 ? "day" : "days"} overdue — {overdueBanner.firstMilestone.projectTitle}
      </div>
    )}
    {overdueBanner.total === 1 && !overdueBanner.firstMilestone && overdueBanner.firstTask && (
      <div
        class="bg-red-50 border border-red-200/30 rounded-xl px-4 py-3 mb-6 text-sm text-red-900"
        role="alert"
      >
        <span class="font-semibold">{overdueBanner.firstTask.description}</span>
        {" "}is {overdueBanner.firstTask.daysOverdue} {overdueBanner.firstTask.daysOverdue === 1 ? "day" : "days"} overdue — {overdueBanner.firstTask.projectTitle}
      </div>
    )}

    {/* Two-column layout: Left = health, Right = actions */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {/* LEFT COLUMN: Projects, Milestones, Activity */}
      <div class="flex flex-col gap-5">

        {/* Active Projects — React island (Phase 35 Plan 03, DASH-16) */}
        <ActiveProjectsCard
          client:load
          projects={data.activeProjects}
          totalCount={data.activeProjects.length}
        />

        {/* Upcoming Deliveries — React island (Phase 35 Plan 02, DASH-11..15) */}
        <UpcomingDeliveriesCard client:load deliveries={data.deliveries} />
      </div>

      {/* RIGHT COLUMN: Tasks */}
      <div class="flex flex-col gap-5">
        <DashboardTasksCard
          client:load
          tasks={data.tasks}
          projects={data.activeProjects.map((p) => ({
            _id: p._id,
            title: p.title,
          }))}
        />
      </div>
    </div>
  </div>
</AdminLayout>
