---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";

const adminName = import.meta.env.ADMIN_NAME || "Liz";
---

<AdminLayout title="Dashboard | La Sprezzatura" pageTitle="Dashboard">
  {/* Greeting (per D-06) */}
  <p class="text-xl font-heading text-charcoal mb-8">
    Welcome back, {adminName}
  </p>

  {/* Summary cards - 3 across (per D-05) */}
  <div class="grid grid-cols-3 gap-8">
    <div class="bg-cream-dark p-6 rounded-xl border border-stone-light/20">
      <p class="text-sm font-body text-stone mb-2">Active Projects</p>
      <p class="text-xl font-heading text-charcoal">--</p>
    </div>
    <div class="bg-cream-dark p-6 rounded-xl border border-stone-light/20">
      <p class="text-sm font-body text-stone mb-2">Pending Orders</p>
      <p class="text-xl font-heading text-charcoal">--</p>
    </div>
    <div class="bg-cream-dark p-6 rounded-xl border border-stone-light/20">
      <p class="text-sm font-body text-stone mb-2">Overdue Items</p>
      <p class="text-xl font-heading text-charcoal">--</p>
    </div>
  </div>

  {/* Quick links section */}
  <div class="mt-8">
    <p class="text-xs uppercase tracking-widest text-stone font-body mb-4">Quick Links</p>
    <div class="flex gap-4">
      <a
        href="/admin/projects"
        class="bg-terracotta text-white text-xs uppercase tracking-widest font-body px-6 py-3 rounded-lg hover:bg-terracotta-light transition-colors"
      >
        View Projects
      </a>
      <a
        href="/admin/rendering"
        class="bg-terracotta text-white text-xs uppercase tracking-widest font-body px-6 py-3 rounded-lg hover:bg-terracotta-light transition-colors"
      >
        Rendering Tool
      </a>
      <a
        href="/admin/settings"
        class="bg-terracotta text-white text-xs uppercase tracking-widest font-body px-6 py-3 rounded-lg hover:bg-terracotta-light transition-colors"
      >
        Studio Settings
      </a>
    </div>
  </div>
</AdminLayout>
