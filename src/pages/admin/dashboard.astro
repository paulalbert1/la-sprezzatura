---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import DashboardTasksCard from "../../components/admin/DashboardTasksCard.tsx";
import UpcomingDeliveriesCard from "../../components/admin/UpcomingDeliveriesCard.tsx";
import ActiveProjectsCard from "../../components/admin/ActiveProjectsCard.tsx";
import ContactCardWrapper from "../../components/admin/ContactCardWrapper.tsx";
import WorkflowStatusCard from "../../components/admin/workflow/WorkflowStatusCard.tsx";
import { getTenantClient } from "../../lib/tenantClient";
import { getAdminDashboardData, DASHBOARD_WORKFLOW_STATS_QUERY } from "../../sanity/queries";
import {
  getOverdueBannerData,
  isMilestoneOverdue,
} from "../../lib/dashboardUtils";
import { format, parseISO } from "date-fns";
import { formatTrade } from "../../lib/trades";

const tenantId = Astro.locals.tenantId;
if (!tenantId) {
  return Astro.redirect("/admin/login");
}
const client = getTenantClient(tenantId);
const data = await getAdminDashboardData(client);

// Compute overdue banner data (now includes items for specific copy)
const overdueBanner = getOverdueBannerData(data.milestones, data.tasks);

// Split milestones into overdue and upcoming
const overdueMilestones = data.milestones.filter(isMilestoneOverdue);
const upcomingMilestones = data.milestones
  .filter((m) => !isMilestoneOverdue(m) && !m.completed)
  .sort((a, b) => (a.date || "").localeCompare(b.date || ""))
  .slice(0, 4);

// Active projects + deliveries are now rendered by React islands
// (ActiveProjectsCard — Plan 03; UpcomingDeliveriesCard — Plan 02) which own
// their own slicing, filtering, and per-stage color maps.

// Date helpers (delivery status + ETA date formatter moved into
// UpcomingDeliveriesCard as of Phase 35 Plan 02).
function formatMilestoneDate(dateStr: string | null): string {
  if (!dateStr) return "";
  try {
    return format(parseISO(dateStr), "MMM d");
  } catch {
    return dateStr;
  }
}

const today = format(new Date(), "EEEE, MMMM d, yyyy");

// ── Workflow Status card (Plan 44-11, WF-08) ──────────────────────────────
// Lightweight projection — no phase.order / phase.execution / gate fields.
// Blocked count uses a status-based approximation (milestone.status ===
// "not_started" AND at least one hardPrereq's status is NOT complete/skipped).
// This is a signal, not source of truth; the tracker page has full fidelity.
interface LiteMilestone { id: string; status: string; hardPrereqs: string[]; }
interface LiteWorkflow {
  _id: string;
  status: string;
  defaults: { clientApprovalDays: number; dormancyDays: number; revisionRounds: number };
  lastActivityAt: string;
  projectId: string;
  phases: Array<{ id: string; milestones: LiteMilestone[] }>;
}

const liteWorkflows = await client.fetch(DASHBOARD_WORKFLOW_STATS_QUERY) as LiteWorkflow[];

let awaitingClientCount = 0;
let approachingDormancyCount = 0;
let blockedMilestonesCount = 0;
const now = Date.now();

for (const wf of liteWorkflows) {
  const allMs = wf.phases.flatMap((p) => p.milestones);
  const statusById = new Map(allMs.map((m) => [m.id, m.status]));

  if (allMs.some((m) => m.status === "awaiting_client" || m.status === "awaiting_payment")) {
    awaitingClientCount += 1;
  }

  if (wf.status === "active") {
    const days = Math.floor((now - new Date(wf.lastActivityAt).getTime()) / 86_400_000);
    if (days >= Math.floor(wf.defaults.dormancyDays * 0.75)) approachingDormancyCount += 1;
  }

  for (const m of allMs) {
    if (m.status !== "not_started") continue;
    const blocked = m.hardPrereqs.some((pid) => {
      const s = statusById.get(pid);
      return s !== undefined && s !== "complete" && s !== "skipped";
    });
    if (blocked) blockedMilestonesCount += 1;
  }
}

const hasAnyWorkflows = liteWorkflows.length > 0;
---

<AdminLayout title="Dashboard - Studio" pageTitle="Dashboard" breadcrumbs={[{ label: "Dashboard" }]}>
  <div>
    {/* Header with date */}
    <div class="flex justify-between items-baseline mb-4" style="margin-top: -15px;">
      <div></div>
      <span class="text-xs text-stone-light font-body">{today}</span>
    </div>

    {/* Overdue Alert Banner - specific single-item copy only */}
    {overdueBanner.total === 1 && overdueBanner.firstMilestone && (
      <div
        class="bg-red-50 border border-red-200/30 rounded-xl px-4 py-3 mb-6 text-sm text-red-900"
        role="alert"
      >
        <span class="font-semibold">{overdueBanner.firstMilestone.name}</span>
        {" "}is {overdueBanner.firstMilestone.daysOverdue} {overdueBanner.firstMilestone.daysOverdue === 1 ? "day" : "days"} overdue — {overdueBanner.firstMilestone.projectTitle}
      </div>
    )}
    {overdueBanner.total === 1 && !overdueBanner.firstMilestone && overdueBanner.firstTask && (
      <div
        class="bg-red-50 border border-red-200/30 rounded-xl px-4 py-3 mb-6 text-sm text-red-900"
        role="alert"
      >
        <span class="font-semibold">{overdueBanner.firstTask.description}</span>
        {" "}is {overdueBanner.firstTask.daysOverdue} {overdueBanner.firstTask.daysOverdue === 1 ? "day" : "days"} overdue — {overdueBanner.firstTask.projectTitle}
      </div>
    )}

    {/* Two-column layout: Left = health, Right = actions */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {/* LEFT COLUMN: Projects, Milestones, Activity */}
      <div class="flex flex-col gap-5">

        {/* Active Projects — React island (Phase 35 Plan 03, DASH-16) */}
        <ActiveProjectsCard
          client:load
          projects={data.activeProjects}
          totalCount={data.activeProjects.length}
        />

        {/* Upcoming Deliveries — React island (Phase 35 Plan 02, DASH-11..15) */}
        <UpcomingDeliveriesCard client:load deliveries={data.deliveries} />
      </div>

      {/* RIGHT COLUMN: Tasks + Contractors + Workflow Status */}
      <div class="flex flex-col gap-5">

        {/* Workflow Status — React island (Phase 44 Plan 11, WF-08) */}
        <WorkflowStatusCard
          client:load
          awaitingClientCount={awaitingClientCount}
          approachingDormancyCount={approachingDormancyCount}
          blockedMilestonesCount={blockedMilestonesCount}
          hasAnyWorkflows={hasAnyWorkflows}
        />

        <DashboardTasksCard
          client:load
          tasks={data.tasks}
          projects={data.activeProjects.map((p) => ({
            _id: p._id,
            title: p.title,
          }))}
        />

        {/* Contractors card — Phase 35 Plan 04 (DASH-17).
            Header-right `+ Add new contractor` CTA routes to the full
            /admin/trades/new create page (D-12: no modal, no inline
            form). Lists the top-6 most-recently-created contractors. */}
        <div class="bg-white rounded-xl border border-stone-light/40 overflow-hidden">
          <div class="px-5 pt-[18px] pb-0">
            <div class="flex items-center justify-between mb-[14px] gap-3">
              <h2
                style="font-family: var(--font-sans); font-size: 10.5px; font-weight: 500; color: #9E8E80; letter-spacing: 0.1em; text-transform: uppercase;"
              >
                Contractor / Vendor
              </h2>
              <a
                href="/admin/trades/new"
                class="inline-flex items-center gap-1.5 text-[13px] font-body text-terracotta border border-terracotta/40 rounded-md px-3 py-1 hover:bg-terracotta/5 transition-colors focus:outline-none focus:ring-1 focus:ring-terracotta"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14"></path>
                  <path d="M12 5v14"></path>
                </svg>
                Add contractor / vendor
              </a>
            </div>
            <hr style="border: none; border-top: 0.5px solid #E8DDD0; margin: 0;" />
          </div>

          {data.contractors.length === 0 ? (
            <p class="text-sm text-stone text-center py-6">No contractors / vendors yet.</p>
          ) : (
            <div>
              {data.contractors.map((contractor: { _id: string; name: string; company: string | null; trades: string[] | null }) => (
                <a
                  href={`/admin/trades/${contractor._id}`}
                  class="flex items-start gap-3 px-5 py-3 hover:bg-cream/50 transition-colors border-b border-stone-light/10 last:border-b-0"
                >
                  <div class="flex-1 min-w-0">
                    <span class="text-[13.5px] font-medium font-body text-charcoal block truncate">
                      {contractor.name}
                    </span>
                    {contractor.company && (
                      <span class="text-[11.5px] text-stone-light font-body block truncate mt-0.5">
                        {contractor.company}
                      </span>
                    )}
                  </div>
                  {contractor.trades && contractor.trades.length > 0 && (
                    <div class="flex flex-wrap gap-1 justify-end max-w-[55%] shrink-0">
                      {contractor.trades.slice(0, 3).map((trade: string) => (
                        <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-body bg-stone-100 text-stone-600">
                          {formatTrade(trade)}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
