---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import FilterPills from "../../components/ui/FilterPills.astro";
import ProjectCard from "../../components/portfolio/ProjectCard.astro";
import { getProjects } from "../../sanity/queries";

export const prerender = true;

let projects: any[] = [];

try {
  projects = await getProjects();
} catch (_e) {
  // Sanity not yet configured -- render empty state gracefully
}

// Extract unique room types and styles from projects
const roomTypes = [...new Set(projects.map((p) => p.roomType).filter(Boolean))];
const styles = [...new Set(projects.map((p) => p.style).filter(Boolean))];
---

<BaseLayout
  title="Portfolio | La Sprezzatura Interior Design"
  description="Explore our portfolio of luxury interior design projects across Long Island and New York City -- living rooms, kitchens, bedrooms, and whole-home renovations."
>
  <!-- Page header -->
  <section class="px-6 md:px-16 lg:px-24 pt-20 pb-12 md:pt-28 md:pb-16">
    <div class="max-w-screen-xl mx-auto">
      <SectionHeading tagline="Our Work">Portfolio</SectionHeading>
      <p class="text-base md:text-lg text-stone font-body max-w-xl leading-relaxed -mt-4">
        Each project is a collaboration — part client vision, part our eye for
        what a space can become.
      </p>
    </div>
  </section>

  <!-- Filters -->
  {
    (roomTypes.length > 0 || styles.length > 0) && (
      <section class="px-6 md:px-16 lg:px-24 pb-10">
        <div class="max-w-screen-xl mx-auto">
          <FilterPills roomTypes={roomTypes} styles={styles} />
        </div>
      </section>
    )
  }

  <!-- Project grid -->
  <section class="px-6 md:px-16 lg:px-24 pb-24 md:pb-32">
    <div class="max-w-screen-xl mx-auto">
      {
        projects.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 lg:gap-12">
            {projects.map((project, index) => (
              <div
                class:list={[
                  index === 0 ? "md:col-span-2" : "",
                ]}
              >
                <ProjectCard project={project} />
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-24">
            <p class="font-heading text-3xl md:text-4xl font-light text-charcoal mb-4">
              Portfolio coming soon
            </p>
            <p class="text-stone font-body">
              We're curating our best work. Check back shortly.
            </p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
