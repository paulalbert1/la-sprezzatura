---
import BaseLayout from "../layouts/BaseLayout.astro";

const lastUpdated = "March 2026";
---

<BaseLayout
  title="Privacy Policy | La Sprezzatura Interior Design"
  description="Privacy policy for La Sprezzatura Interior Design website."
  noindex={true}
>
  <section class="py-16 md:py-24 px-6">
    <div class="max-w-prose mx-auto">
      <!-- Page title -->
      <div class="mb-12 md:mb-16">
        <h1
          class="font-heading text-4xl md:text-5xl font-light text-charcoal leading-tight mb-4"
        >
          Privacy Policy
        </h1>
        <p class="font-body text-sm text-stone">Last updated: {lastUpdated}</p>
      </div>

      <!-- Policy content -->
      <div class="space-y-12 font-body text-charcoal">
        <!-- Intro -->
        <p class="text-stone leading-relaxed">
          Your privacy matters to us. This policy explains what information we
          collect when you visit lasprezz.com, how we use it, and your rights
          regarding your personal data. We've written it in plain English — no
          legalese.
        </p>

        <!-- 1. Information We Collect -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            1. Information We Collect
          </h2>
          <p class="text-stone leading-relaxed mb-4">
            We only collect information you provide directly to us:
          </p>
          <ul class="space-y-3 text-stone leading-relaxed">
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>
                <strong class="font-medium text-charcoal"
                  >Contact form submissions</strong
                > — your name, email address, phone number (optional), and project
                details when you reach out through our website
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>
                <strong class="font-medium text-charcoal"
                  >Website usage data</strong
                > — standard analytics data such as pages visited and approximate
                geographic region, used to understand how visitors use the site
              </span>
            </li>
          </ul>
        </section>

        <!-- 2. How We Use Your Information -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            2. How We Use Your Information
          </h2>
          <p class="text-stone leading-relaxed mb-4">
            We use the information you provide to:
          </p>
          <ul class="space-y-3 text-stone leading-relaxed">
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>Respond to your inquiry in a timely manner</span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>Schedule and prepare for initial consultations</span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>Improve the website experience for future visitors</span>
            </li>
          </ul>
          <p class="text-stone leading-relaxed mt-4">
            We do not sell, rent, or share your personal information with third
            parties for marketing purposes.
          </p>
        </section>

        <!-- 3. Third-Party Services -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            3. Third-Party Services
          </h2>
          <p class="text-stone leading-relaxed mb-4">
            This website uses the following third-party services to operate:
          </p>
          <ul class="space-y-4 text-stone leading-relaxed">
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>
                <strong class="font-medium text-charcoal">Cal.com</strong> — used
                for scheduling consultations. When you book an appointment, Cal.com
                collects the information needed to schedule your meeting. Their privacy
                policy applies to that interaction.
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>
                <strong class="font-medium text-charcoal">Resend</strong> — used
                to deliver email responses to your contact form submissions. Resend
                processes the email address you provide. Their privacy policy applies
                to that processing.
              </span>
            </li>
          </ul>
          <p class="text-stone leading-relaxed mt-4">
            Each service has its own privacy policy, and we encourage you to
            review them if you have questions about how they handle your data.
          </p>
        </section>

        <!-- 4. Cookies and Tracking -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            4. Cookies and Tracking
          </h2>
          <p class="text-stone leading-relaxed">
            We use only essential cookies — the minimum needed to keep the site
            functioning properly. We do not use third-party advertising cookies,
            tracking pixels, or behavioral targeting tools. If we add analytics
            in the future, we'll update this policy to reflect that.
          </p>
        </section>

        <!-- 5. Data Retention -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            5. Data Retention
          </h2>
          <p class="text-stone leading-relaxed">
            Contact form submissions are retained for as long as needed to
            manage our business relationship with you. If you would like your
            information deleted, please contact us and we'll take care of it
            promptly.
          </p>
        </section>

        <!-- 6. Your Rights -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            6. Your Rights
          </h2>
          <p class="text-stone leading-relaxed mb-4">
            You have the right to:
          </p>
          <ul class="space-y-3 text-stone leading-relaxed">
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span
                >Access the personal information we hold about you</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span>Request corrections to inaccurate information</span>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="mt-2 block w-1 h-1 rounded-full bg-terracotta flex-shrink-0"
                aria-hidden="true"
              ></span>
              <span
                >Request deletion of your personal data from our records</span
              >
            </li>
          </ul>
          <p class="text-stone leading-relaxed mt-4">
            To exercise any of these rights, email us at{" "}
            <a
              href="mailto:liz@lasprezz.com"
              class="text-terracotta hover:text-terracotta-light underline underline-offset-2 transition-colors"
            >
              liz@lasprezz.com
            </a>.
          </p>
        </section>

        <!-- 7. Changes to This Policy -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            7. Changes to This Policy
          </h2>
          <p class="text-stone leading-relaxed">
            We may update this privacy policy from time to time. The "Last
            updated" date at the top of this page reflects when changes were
            last made. We encourage you to review this page periodically if
            you'd like to stay informed.
          </p>
        </section>

        <!-- 8. Contact -->
        <section>
          <h2
            class="font-heading text-2xl md:text-3xl font-light text-charcoal mb-4"
          >
            8. Contact
          </h2>
          <p class="text-stone leading-relaxed">
            If you have any questions about this privacy policy or how we handle
            your data, please reach out:
          </p>
          <div class="mt-4 p-6 bg-cream-dark border border-stone-light/30">
            <p class="font-body text-charcoal">
              La Sprezzatura Interior Design<br />
              <a
                href="mailto:liz@lasprezz.com"
                class="text-terracotta hover:text-terracotta-light underline underline-offset-2 transition-colors"
              >
                liz@lasprezz.com
              </a>
            </p>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
