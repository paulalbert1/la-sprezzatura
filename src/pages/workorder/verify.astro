---
export const prerender = false;

import { redis } from "../../lib/redis";
import { createSession } from "../../lib/session";

const token = Astro.url.searchParams.get("token");

if (!token) {
  return Astro.redirect("/workorder/login?error=expired");
}

// Atomic get-and-delete: single-use token enforcement
const rawValue = await redis.getdel(`magic:${token}`) as string | null;

if (!rawValue) {
  return Astro.redirect("/workorder/login?error=expired");
}

// Parse token data -- handle legacy plain string and new JSON format
let tokenData: any;
try {
  tokenData = JSON.parse(rawValue);
} catch {
  // Legacy format: plain string is a contractor ID
  tokenData = { entityId: rawValue, role: 'contractor' };
}

if (tokenData.dualRole) {
  // Dual role: redirect to role selection page
  return Astro.redirect(
    `/portal/role-select?clientId=${tokenData.clientId}&contractorId=${tokenData.contractorId}`
  );
}

// Single role: create session and redirect to appropriate dashboard
const role = tokenData.role || 'contractor';
await createSession(Astro.cookies, tokenData.entityId, role);
const dashboard = role === 'client' ? '/portal/dashboard' : '/workorder/dashboard';
return Astro.redirect(dashboard);
---
