---
export const prerender = false;

import { redis } from "../../lib/redis";
import { createSession } from "../../lib/session";

const token = Astro.url.searchParams.get("token");

if (!token) {
  return Astro.redirect("/workorder/login?error=expired");
}

// Peek first to check reusable flag; only consume if single-use.
const isDemo = token.startsWith("demo-");
const peeked = await redis.get(`magic:${token}`) as string | object | null;
let parsedPeek: any = null;
if (peeked) {
  parsedPeek = typeof peeked === "object" ? peeked : (() => { try { return JSON.parse(peeked); } catch { return null; } })();
}
const isReusable = isDemo || parsedPeek?.reusable === true;
const rawValue = isReusable
  ? peeked
  : await redis.getdel(`magic:${token}`) as string | null;

if (!rawValue) {
  return Astro.redirect("/workorder/login?error=expired");
}

// Parse token data -- handle Upstash auto-parsed objects, JSON strings, and legacy plain strings
let tokenData: any;
if (typeof rawValue === 'object' && rawValue !== null) {
  tokenData = rawValue;
} else if (typeof rawValue === 'string') {
  try {
    tokenData = JSON.parse(rawValue);
  } catch {
    tokenData = { entityId: rawValue, role: 'contractor' };
  }
} else {
  return Astro.redirect("/workorder/login?error=expired");
}

if (tokenData.dualRole) {
  // Dual role: redirect to role selection page
  return Astro.redirect(
    `/portal/role-select?clientId=${tokenData.clientId}&contractorId=${tokenData.contractorId}`
  );
}

// Single role: create session and redirect
const role = tokenData.role || 'contractor';
await createSession(Astro.cookies, tokenData.entityId, role);

const redirectTo = Astro.url.searchParams.get("redirect");
const safeRedirect =
  redirectTo && redirectTo.startsWith("/") && !redirectTo.startsWith("//")
    ? redirectTo
    : (role === 'client' ? '/portal/dashboard' : '/workorder/dashboard');
return Astro.redirect(safeRedirect);
---
