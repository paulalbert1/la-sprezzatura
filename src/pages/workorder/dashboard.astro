---
export const prerender = false;

import PortalLayout from "../../components/portal/PortalLayout.astro";
import { getContractorById, getProjectsByContractorId } from "../../sanity/queries";
import { sanityClient } from "sanity:client";
import { getPortalBrand } from "../../lib/portal/portalBrand";

// contractorId injected by middleware (guaranteed by auth guard)
const contractorId = Astro.locals.contractorId!;
const tenant = await getPortalBrand(sanityClient);

// Fetch contractor name for greeting
const contractor = await getContractorById(contractorId);
const firstName = contractor?.name?.split(" ")[0] || "there";

// Fetch all assigned projects for this contractor
const projects = await getProjectsByContractorId(contractorId) || [];

// Phase 39 Plan 04 Task 4 — "All work orders" list for this contractor.
// Sorted by lastSentAt desc; only includes work orders that have actually
// been sent (defined(lastSentAt)).
type ContractorWorkOrder = {
  _id: string;
  projectId: string;
  projectTitle: string;
  lastSentAt: string;
};
const workOrders: ContractorWorkOrder[] =
  (await sanityClient.fetch(
    `*[_type == "workOrder" && contractor._ref == $contractorId && defined(lastSentAt)]
      | order(lastSentAt desc) {
        _id,
        "projectId": project._ref,
        "projectTitle": project->title,
        lastSentAt
      }`,
    { contractorId },
  )) ?? [];

// Single-project contractors see their project card (no auto-redirect)
---

<PortalLayout title={`Work Orders | ${tenant.displayName}`} tenant={tenant}>
  <main class="flex-1">
    <div class="max-w-2xl mx-auto px-6 py-12 md:py-20">
      {/* Greeting */}
      <h1 class="font-heading text-4xl md:text-5xl font-light text-charcoal text-center mb-2">
        Welcome, {firstName}
      </h1>
      <p class="text-lg text-stone font-body text-center mb-8">
        Your work orders will appear here.
      </p>

      {/* Project cards */}
      {projects.length > 0 && (
        <div class:list={["grid gap-4", projects.length >= 2 ? "md:grid-cols-2" : "grid-cols-1"]}>
          {projects.map((project: any) => {
            const assignment = project.assignment;
            const dateRange = assignment?.startDate && assignment?.endDate
              ? `${new Date(assignment.startDate).toLocaleDateString()} - ${new Date(assignment.endDate).toLocaleDateString()}`
              : "Dates pending";
            return (
              <a href={`/workorder/project/${project._id}`} class="block bg-cream-dark border border-stone-light/20 p-6 hover:border-terracotta/40 transition-colors rounded-lg focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:outline-none">
                <h3 class="font-heading text-xl font-light text-charcoal mb-2">{project.title}</h3>
                <p class="text-xs text-stone uppercase tracking-wider font-body mb-3">
                  {[project.projectAddress?.street, project.projectAddress?.city, project.projectAddress?.state].filter(Boolean).join(', ') || "Address pending"}
                </p>
                <p class="text-xs text-stone uppercase tracking-wider font-body">{dateRange}</p>
              </a>
            );
          })}
        </div>
      )}

      {/* Empty state */}
      {projects.length === 0 && (
        <div class="text-center py-12">
          <h2 class="font-heading text-2xl font-light text-charcoal mb-4">No Work Orders Yet</h2>
          <p class="text-stone font-body leading-relaxed">
            You'll be notified via email when new work orders are assigned.
          </p>
        </div>
      )}

      {/* Phase 39 Plan 04 Task 4 — All work orders */}
      <section class="mt-12">
        <h2 class="text-[11.5px] font-semibold uppercase tracking-[0.14em] text-stone mb-4">
          All work orders
        </h2>
        {workOrders.length === 0 ? (
          <div class="text-center py-8">
            <h3 class="text-[13px] font-semibold text-charcoal">No work orders yet</h3>
            <p class="text-[11.5px] text-stone mt-2">
              Your designer hasn't sent any work orders. Check back when one is issued.
            </p>
          </div>
        ) : (
          <div class="bg-cream-dark border border-stone-light/20 rounded-lg overflow-hidden">
            {workOrders.map((wo) => (
              <a
                href={`/workorder/project/${wo.projectId}/orders/${wo._id}`}
                class="flex items-center justify-between px-4 py-3 border-b border-stone-light/20 last:border-0 hover:bg-cream transition-colors"
              >
                <div>
                  <div class="text-sm text-charcoal font-body">{wo.projectTitle}</div>
                  <div class="text-[11.5px] text-stone font-body mt-0.5">
                    Sent {new Date(wo.lastSentAt).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </div>
                </div>
                <span class="text-stone">›</span>
              </a>
            ))}
          </div>
        )}
      </section>

    </div>
  </main>
</PortalLayout>
