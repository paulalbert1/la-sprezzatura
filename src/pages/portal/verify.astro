---
export const prerender = false;

import { redis } from "../../lib/redis";
import { createSession } from "../../lib/session";

const token = Astro.url.searchParams.get("token");

if (!token) {
  return Astro.redirect("/portal/login?error=expired");
}

// Demo tokens (prefixed "demo-") are reusable; real tokens are single-use
const isDemo = token.startsWith("demo-");
const rawValue = isDemo
  ? await redis.get(`magic:${token}`) as string | null
  : await redis.getdel(`magic:${token}`) as string | null;

if (!rawValue) {
  return Astro.redirect("/portal/login?error=expired");
}

// Parse token data -- handle Upstash auto-parsed objects, JSON strings, and legacy plain strings
let tokenData: any;
if (typeof rawValue === 'object' && rawValue !== null) {
  tokenData = rawValue;
} else if (typeof rawValue === 'string') {
  try {
    tokenData = JSON.parse(rawValue);
  } catch {
    tokenData = { entityId: rawValue, role: 'client' };
  }
} else {
  return Astro.redirect("/portal/login?error=expired");
}

if (tokenData.dualRole) {
  // Dual role: redirect to role selection page
  return Astro.redirect(
    `/portal/role-select?clientId=${tokenData.clientId}&contractorId=${tokenData.contractorId}`
  );
}

// Single role: create session and redirect to appropriate dashboard
const role = tokenData.role || 'client';
await createSession(Astro.cookies, tokenData.entityId, role);
const dashboard = role === 'contractor' ? '/workorder/dashboard' : '/portal/dashboard';
return Astro.redirect(dashboard);
---
