---
export const prerender = false;

import PortalLayout from "../../components/portal/PortalLayout.astro";
import RoleSelectionForm from "../../components/portal/RoleSelectionForm.tsx";
import { createSession } from "../../lib/session";

// Handle POST: create session with selected role
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const role = formData.get("role") as string;
  const entityId = formData.get("entityId") as string;

  if (role && entityId) {
    let sessionRole: 'client' | 'contractor' | 'building_manager' = 'client';
    if (role === 'contractor') sessionRole = 'contractor';
    if (role === 'building_manager') sessionRole = 'building_manager';
    await createSession(Astro.cookies, entityId, sessionRole);
    const dashboards: Record<string, string> = {
      client: '/portal/dashboard',
      contractor: '/workorder/dashboard',
      building_manager: '/building/dashboard',
    };
    return Astro.redirect(dashboards[sessionRole]);
  }
}

// GET: render role selection form
const clientId = Astro.url.searchParams.get("clientId");
const contractorId = Astro.url.searchParams.get("contractorId");
const buildingManagerEmail = Astro.url.searchParams.get("buildingManagerEmail");

// If no role params at all, redirect to login
if (!clientId && !contractorId && !buildingManagerEmail) {
  return Astro.redirect("/portal/login");
}
---

<PortalLayout title="Choose Your Portal | La Sprezzatura">
  <main class="flex-1 flex items-center justify-center px-6">
    <div class="w-full max-w-sm text-center">
      {/* Brand mark */}
      <p class="text-xs text-stone tracking-[0.2em] uppercase font-body mb-8">
        La Sprezzatura
      </p>

      {/* Heading */}
      <h2 class="font-heading text-2xl font-light text-charcoal mb-3">
        Choose Your Portal
      </h2>

      {/* Body */}
      <p class="text-base text-stone font-body mb-8">
        Your email is associated with multiple accounts.
      </p>

      {/* Role selection buttons */}
      <RoleSelectionForm client:load clientId={clientId} contractorId={contractorId} buildingManagerEmail={buildingManagerEmail} />
    </div>
  </main>
</PortalLayout>
