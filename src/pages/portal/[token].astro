---
export const prerender = false;

import PortalLayout from "../../components/portal/PortalLayout.astro";

// Old PURL links now redirect with an upgrade message
// No rate limiting or Sanity query needed -- just display the message
---

<PortalLayout title="Portal Upgraded | La Sprezzatura">
  <main class="flex-1 flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      {/* Brand mark */}
      <p class="text-xs text-stone tracking-[0.2em] uppercase font-body mb-8">
        La Sprezzatura
      </p>

      <h1 class="font-heading text-3xl font-light text-charcoal mb-4">
        We've Upgraded Your Portal
      </h1>
      <p class="text-stone font-body leading-relaxed mb-8">
        For your security, we've added email verification. Enter your email address to access your projects.
      </p>
      <a
        href="/portal/login"
        class="inline-block border border-stone-light/40 px-6 py-3 text-sm tracking-widest uppercase text-stone hover:text-terracotta hover:border-terracotta transition-colors font-body"
      >
        Go to Login
      </a>
    </div>
  </main>
</PortalLayout>
