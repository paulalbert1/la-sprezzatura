---
export const prerender = false;

import PortalLayout from "../../components/portal/PortalLayout.astro";
import StatusBadge from "../../components/portal/StatusBadge.astro";
import { getProjectsByClientId, getClientById } from "../../sanity/queries";
import { STAGE_META, type StageKey } from "../../lib/portalStages";
import { getProjectAccessState } from "../../lib/projectVisibility";
import { ENGAGEMENT_LABELS } from "../../lib/portal/engagementLabels";
import { sanityClient } from "sanity:client";
import { getPortalBrand } from "../../lib/portal/portalBrand";

const tenant = await getPortalBrand(sanityClient);

// clientId injected by middleware (guaranteed by auth guard)
const clientId = Astro.locals.clientId!;

// Fetch client name for greeting
const client = await getClientById(clientId);
const firstName = client?.name?.split(" ")[0] || "there";

// Fetch all portal-enabled projects for this client
const projects = (await getProjectsByClientId(clientId)) || [];

// Classify each project via getProjectAccessState so we can render:
//   active            -> top "Active" grid (full link cards)
//   completed-visible -> inside Past Projects accordion as link cards
//   expired           -> inside Past Projects accordion as greyed-out stubs
//                        ("Access expired - contact your designer to extend")
//   hidden            -> not surfaced at all
type Bucket = {
  project: any;
  state: ReturnType<typeof getProjectAccessState>;
};

const classified: Bucket[] = projects.map((p: any) => ({
  project: p,
  state: getProjectAccessState(p),
}));

const activeProjects = classified
  .filter((b) => b.state === "active")
  .map((b) => b.project);
const pastProjects = classified.filter(
  (b) => b.state === "completed-visible" || b.state === "expired",
);
const activeCount = activeProjects.length;
---

<PortalLayout title={`Dashboard | ${tenant.displayName}`} tenant={tenant}>
  <main class="flex-1">
    <div class="max-w-2xl mx-auto px-6 py-12 md:py-20">
      {/* Brand mark */}
      <p class="text-xs text-stone tracking-[0.2em] uppercase font-body mb-8 text-center">
        {tenant.wordmark}
      </p>
      <p class="text-xs text-stone/60 font-body text-center mb-4 -mt-6">Client Portal</p>

      {/* Greeting */}
      <h1 class="font-heading text-4xl md:text-5xl font-light text-charcoal text-center mb-2">
        Welcome back, {firstName}
      </h1>
      <p class="text-lg text-stone font-body text-center mb-8">
        {activeCount === 0
          ? "No active projects"
          : activeCount === 1
            ? "1 active project"
            : `${activeCount} active projects`}
      </p>

      {/* Empty state */}
      {projects.length === 0 && (
        <div class="text-center py-12">
          <h2 class="font-heading text-2xl font-light text-charcoal mb-4">
            No Projects Yet
          </h2>
          <p class="text-stone font-body leading-relaxed">
            Your designer hasn't set up any projects for you yet. If you believe this is an error, please contact{" "}
            <a
              href={`mailto:${tenant.contactEmail}`}
              class="text-terracotta hover:text-terracotta-light transition-colors underline underline-offset-2"
            >
              {tenant.contactEmail}
            </a>
            .
          </p>
        </div>
      )}

      {/* Active project cards */}
      {activeProjects.length > 0 && (
        <div class:list={[
          "grid gap-4",
          activeProjects.length >= 2 ? "md:grid-cols-2" : "grid-cols-1",
        ]}>
          {activeProjects.map((project: any) => {
            const stage = project.pipelineStage as StageKey;
            const stageMeta = STAGE_META[stage] || { title: stage };
            return (
              <a
                href={`/portal/project/${project._id}`}
                class="block bg-cream-dark border border-stone-light/20 p-6 hover:border-terracotta/40 transition-colors cursor-pointer rounded-lg focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:outline-none"
              >
                <h3 class="font-heading text-xl font-light text-charcoal mb-2">
                  {project.title}
                </h3>
                {project.engagementType && (
                  <p class="text-xs text-stone uppercase tracking-wider font-body mb-3">
                    {ENGAGEMENT_LABELS[project.engagementType] || project.engagementType}
                  </p>
                )}
                <StatusBadge
                  stage={stageMeta.title}
                  isComplete={stage === "closeout"}
                />
              </a>
            );
          })}
        </div>
      )}

      {/* Past projects accordion: completed-visible cards + expired stubs.
          Uses native <details> so the toggle is keyboard-accessible without
          shipping JS. Closed by default — clients land focused on active work. */}
      {pastProjects.length > 0 && (
        <details class="group mt-10 border-t border-stone-light/30 pt-6">
          <summary
            class="flex items-center justify-between cursor-pointer list-none text-xs text-stone uppercase tracking-widest font-body py-2 px-1 -mx-1 rounded hover:text-terracotta transition-colors focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:outline-none"
          >
            <span>
              Past Projects
              <span class="text-stone/60 normal-case tracking-normal ml-2">
                ({pastProjects.length})
              </span>
            </span>
            <span
              aria-hidden="true"
              class="text-base transition-transform group-open:rotate-180"
            >
              &#x25BE;
            </span>
          </summary>

          <div class:list={[
            "grid gap-4 mt-4",
            pastProjects.length >= 2 ? "md:grid-cols-2" : "grid-cols-1",
          ]}>
            {pastProjects.map(({ project, state }) => {
              if (state === "completed-visible") {
                return (
                  <a
                    href={`/portal/project/${project._id}`}
                    class="block bg-cream-dark border border-stone-light/30 p-6 hover:border-terracotta/40 transition-colors cursor-pointer rounded-lg focus-visible:ring-2 focus-visible:ring-terracotta focus-visible:outline-none"
                  >
                    <h3 class="font-heading text-xl font-light text-stone mb-2">
                      {project.title}
                    </h3>
                    {project.engagementType && (
                      <p class="text-xs text-stone uppercase tracking-wider font-body mb-3">
                        {ENGAGEMENT_LABELS[project.engagementType] || project.engagementType}
                      </p>
                    )}
                    <StatusBadge stage="Closeout" isComplete={true} />
                  </a>
                );
              }
              // state === "expired": no link, no detail data; just a greyed
              // stub explaining what happened and how to recover access.
              return (
                <div
                  aria-disabled="true"
                  class="block bg-cream-dark/50 border border-stone-light/20 p-6 rounded-lg opacity-70"
                >
                  <h3 class="font-heading text-xl font-light text-stone/70 mb-2">
                    {project.title}
                  </h3>
                  {project.engagementType && (
                    <p class="text-xs text-stone/60 uppercase tracking-wider font-body mb-3">
                      {ENGAGEMENT_LABELS[project.engagementType] || project.engagementType}
                    </p>
                  )}
                  <p class="text-xs text-stone/70 font-body leading-relaxed">
                    Access expired — contact your designer to extend.
                  </p>
                </div>
              );
            })}
          </div>
        </details>
      )}

      {/* Sign out link */}
      <div class="mt-16 text-center">
        <a
          href="/portal/logout"
          class="text-xs text-stone hover:text-terracotta transition-colors uppercase tracking-widest font-body py-2 px-4 border border-stone-light/30 rounded"
        >
          Sign Out
        </a>
      </div>
    </div>
  </main>
</PortalLayout>
