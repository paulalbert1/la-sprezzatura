---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import ProcessStep from "../components/ui/ProcessStep.astro";
import Button from "../components/ui/Button.astro";
import { getSiteSettings } from "../sanity/queries";

let settings = null;

try {
  settings = await getSiteSettings();
} catch (_e) {
  // Sanity not configured yet -- render gracefully
}

const heroTitle = settings?.siteTitle ?? "La Sprezzatura";
const heroTagline = settings?.tagline ?? "Luxury Interior Design · Long Island & New York City";
---

<BaseLayout
  title="La Sprezzatura | Luxury Interior Design"
  description="Award-winning luxury interior design studio serving Long Island and New York City. Creating spaces that feel effortlessly beautiful."
  transparentHeader={true}
>
  <!-- 1. Hero -- full viewport with text overlay -->
  <Hero
    images={settings?.heroSlideshow}
    title={heroTitle}
    tagline={heroTagline}
  />

  <!-- 2. Portfolio Teaser -->
  <section class="px-6 md:px-16 lg:px-24 py-24 md:py-32" data-animate="fade-up">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
      <div>
        <p class="text-xs uppercase tracking-widest text-stone mb-6 font-body">
          Portfolio
        </p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-light text-charcoal leading-tight mb-8">
          Spaces that tell<br />your story.
        </h2>
        <p class="text-base md:text-lg text-stone font-body leading-relaxed mb-10">
          From whole-home renovations to single-room transformations, every
          project is a collaboration between your vision and our eye for what
          a space can become.
        </p>
        <Button href="/portfolio" variant="outline" size="lg">View Our Work</Button>
      </div>
      <a href="/portfolio" class="group block">
        <div class="relative overflow-hidden aspect-[4/5]">
          <img
            src="https://cdn.sanity.io/images/e9tpu2os/production/ed14f099e6f65765e32e080cdec175ac61b61c06-1497x1042.webp?w=800&h=1000&fit=crop&auto=format"
            alt="Gramercy Park apartment — collected living room with brass and velvet accents"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/10 transition-colors duration-500"></div>
        </div>
      </a>
    </div>
  </section>

  <!-- 3. About Teaser -->
  <section
    class="px-6 md:px-16 lg:px-24 py-24 md:py-32 bg-cream-dark"
    data-animate="fade-up"
  >
    <div
      class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center"
    >
      <!-- Elizabeth portrait -->
      <div class="order-2 md:order-1">
        <div class="aspect-[4/5] w-full max-w-sm md:max-w-none overflow-hidden">
          <img
            src="https://cdn.sanity.io/images/e9tpu2os/production/dac5e9586287d906adbc2bb2b8f52a4c17eae00c-534x732.jpg?w=600&h=750&fit=crop&auto=format"
            alt="Elizabeth Olivier, founder of La Sprezzatura"
            class="w-full h-full object-cover object-top"
            loading="lazy"
          />
        </div>
      </div>
      <!-- Text -->
      <div class="order-1 md:order-2">
        <p class="text-xs uppercase tracking-widest text-stone mb-6 font-body">
          About
        </p>
        <h2
          class="font-heading text-4xl md:text-5xl lg:text-6xl font-light text-charcoal leading-tight mb-8"
        >
          Design should feel<br />effortless.
        </h2>
        <p class="text-base md:text-lg text-stone font-body leading-relaxed mb-4">
          Elizabeth brings a thoughtful, editorial eye to every project — whether a full
          home renovation or a carefully curated refresh. Her work blends timeless
          proportion with unexpected warmth.
        </p>
        <p class="text-base md:text-lg text-stone font-body leading-relaxed mb-10">
          Based on Long Island and serving clients throughout New York City, La
          Sprezzatura creates spaces that are beautiful to live in — not just to
          photograph.
        </p>
        <Button href="/about" variant="outline">Learn More</Button>
      </div>
    </div>
  </section>

  <!-- 4. Process Preview -->
  <section
    class="px-6 md:px-16 lg:px-24 py-24 md:py-32"
    data-animate="fade-up"
  >
    <div class="max-w-screen-xl mx-auto">
      <SectionHeading tagline="How We Work">Our Process</SectionHeading>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12"
      >
        <ProcessStep
          number={1}
          title="Discovery"
          description="We begin with a deep conversation about your life, your aesthetic, and what your space needs to do for you."
        />
        <ProcessStep
          number={2}
          title="Concept"
          description="We develop a cohesive vision — mood boards, space planning, and material palettes that capture the feeling of your future home."
        />
        <ProcessStep
          number={3}
          title="Design"
          description="Every detail is refined: custom furniture, fabric selections, lighting, and art — all chosen with intention and care."
        />
        <ProcessStep
          number={4}
          title="Installation"
          description="We orchestrate the final reveal, coordinating all trades and deliveries so your home arrives as one complete, beautiful whole."
        />
      </div>
      <div class="mt-14 flex justify-center md:justify-start">
        <Button href="/process" variant="outline">See the Full Process</Button>
      </div>
    </div>
  </section>

  <!-- 5. Testimonial (placeholder -- populated from Sanity in future) -->
  <section
    class="px-6 md:px-16 lg:px-24 py-24 md:py-32 bg-cream-dark"
    data-animate="fade-up"
  >
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs uppercase tracking-widest text-stone mb-10 font-body">
        What Clients Say
      </p>
      <blockquote
        class="font-heading text-2xl md:text-3xl lg:text-4xl font-light text-charcoal leading-relaxed italic mb-8"
      >
        "Working with Elizabeth transformed not just our home, but how we live in it.
        Every room tells a story we couldn't have imagined without her."
      </blockquote>
      <cite class="text-sm text-stone font-body tracking-wide not-italic">
        — La Sprezzatura client, East Hampton
      </cite>
    </div>
  </section>

  <!-- 6. CTA -->
  <section
    class="px-6 md:px-16 lg:px-24 py-24 md:py-32"
    data-animate="fade-up"
  >
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
      <div>
        <p class="text-xs uppercase tracking-widest text-stone mb-6 font-body">
          Let's Connect
        </p>
        <h2
          class="font-heading text-4xl md:text-5xl lg:text-6xl font-light text-charcoal leading-tight mb-8"
        >
          Ready to transform<br />your space?
        </h2>
        <p
          class="text-base md:text-lg text-stone font-body leading-relaxed mb-10"
        >
          Every beautiful room begins with a conversation. Tell us about your
          project and let's start envisioning what's possible.
        </p>
        <Button href="/contact" size="lg">Start the Conversation</Button>
      </div>
      <div class="hidden md:block">
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src="https://cdn.sanity.io/images/e9tpu2os/production/2986c6b2c9c06973e5bc5d83ddb430d77af7d48b-730x990.jpg?w=600&h=800&fit=crop&auto=format"
            alt="Elizabeth Olivier"
            class="w-full h-full object-cover object-top"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
