---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import ContactForm from "../components/contact/ContactForm";
import CalBooking from "../components/contact/CalBooking";

const calcomLink = import.meta.env.PUBLIC_CALCOM_LINK || "lasprezzatura/consultation";
---

<BaseLayout
  title="Contact | La Sprezzatura Interior Design"
  description="Get in touch with La Sprezzatura for interior design consultations on Long Island and in New York City. Schedule a complimentary consultation or send us a message."
>
  <!-- Page Header -->
  <section class="py-20 md:py-28 px-8 md:px-16 lg:px-24 max-w-7xl mx-auto" data-animate="fade-up">
    <SectionHeading tagline="Get In Touch">
      Let&rsquo;s Talk About Your Space
    </SectionHeading>
    <p class="text-stone-dark font-body text-lg md:text-xl leading-relaxed max-w-2xl">
      Every exceptional space begins with a conversation. Tell us about your vision,
      your home, and how you live&mdash;and we&rsquo;ll show you what&rsquo;s possible.
    </p>
  </section>

  <!-- Contact Form + Info -->
  <section class="pb-20 md:pb-28 px-8 md:px-16 lg:px-24 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Contact Form (2/3 width on desktop) -->
      <div class="lg:col-span-2" data-animate="fade-up">
        <ContactForm client:load calcomLink={calcomLink} />
      </div>

      <!-- Contact Info Sidebar -->
      <aside class="lg:col-span-1 space-y-10" data-animate="fade-up">

        <!-- Studio Details -->
        <div>
          <p class="text-xs uppercase tracking-widest text-stone font-body mb-6">
            Studio Details
          </p>
          <ul class="space-y-4 text-charcoal font-body">
            <li>
              <span class="text-xs uppercase tracking-widest text-stone block mb-1">Email</span>
              <a
                href="mailto:liz@lasprezz.com"
                class="text-charcoal hover:text-terracotta transition-colors"
              >
                liz@lasprezz.com
              </a>
            </li>
            <li>
              <span class="text-xs uppercase tracking-widest text-stone block mb-1">Location</span>
              <span class="text-charcoal">Long Island &amp; New York City</span>
            </li>
            <li>
              <span class="text-xs uppercase tracking-widest text-stone block mb-1">Response Time</span>
              <span class="text-charcoal">Within 24 business hours</span>
            </li>
          </ul>
        </div>

        <!-- Divider -->
        <div class="w-12 h-0.5 bg-terracotta"></div>

        <!-- Book prompt -->
        <div>
          <p class="text-xs uppercase tracking-widest text-stone font-body mb-4">
            Prefer to book directly?
          </p>
          <p class="text-stone-dark font-body text-sm leading-relaxed mb-5">
            Skip the wait and schedule your complimentary consultation right away using
            our online booking calendar below.
          </p>
          <div class="flex items-center gap-3 text-terracotta">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
            <span class="text-xs uppercase tracking-widest font-body">See booking calendar below</span>
          </div>
        </div>

      </aside>
    </div>
  </section>

  <!-- Cal.com Booking Widget -->
  <section class="pb-24 md:pb-32 px-8 md:px-16 lg:px-24 max-w-7xl mx-auto">
    <div data-animate="fade-up" class="mb-12">
      <SectionHeading tagline="Book a Consultation">
        Schedule a Time
      </SectionHeading>
      <p class="text-stone-dark font-body text-lg leading-relaxed max-w-xl">
        Our consultations are complimentary. We&rsquo;ll discuss your space, your vision,
        and how we can bring it to life together.
      </p>
    </div>

    <!-- Cal.com inline embed: client:visible lazy-loads once in viewport -->
    <div
      class="min-h-[600px] border border-stone-light/30 bg-cream-dark"
      data-animate="fade-up"
    >
      <CalBooking client:visible calLink={calcomLink} />
    </div>
  </section>
</BaseLayout>
